@page "/admin"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Options
@using Xenopairings.Models
@using Xenopairings.Services.Auth
@using Xenopairings.Services.Organizations
@using Xenopairings.Services.Tournaments
@inject ITournamentService TournamentService
@inject IAuthService AuthService
@inject IOrganizationService OrgService
@inject IOptions<AdminSettings> AdminOptions

<PageTitle>Admin — Xenopairings</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (!_isAdmin)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Access denied</h3>
        <p>This page is for administrators only.</p>
        <a href="/" class="btn btn-outline-secondary mt-2">Home</a>
    </div>
}
else
{
    <h1>Admin panel</h1>
    <p class="text-muted">Full access — includes private tournaments.</p>

    @* ── Users ───────────────────────────────────────────────────────────────── *@
    <h2 class="h5 mt-4">Users (@_users.Count)</h2>
    <div class="table-responsive mb-4">
        <table class="table table-sm">
            <thead>
                <tr><th>Email</th><th>Joined</th><th>Badges</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var u in _users)
                {
                    <tr>
                        <td>@u.Email</td>
                        <td class="text-muted small text-nowrap">
                            @u.CreatedAt.ToLocalTime().ToString("d MMM yyyy")
                        </td>
                        <td>
                            @if (AdminOptions.Value.IsAdmin(u.Email))
                            {
                                <span class="badge text-bg-danger me-1">admin</span>
                            }
                            @if (u.IsVip)
                            {
                                <span class="badge text-bg-success">$ VIP</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm @(u.IsVip ? "btn-outline-secondary" : "btn-outline-success")"
                                    @onclick="() => ToggleVip(u)"
                                    disabled="@_saving">
                                @(u.IsVip ? "Revoke VIP" : "Grant VIP")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!string.IsNullOrEmpty(_statusMsg))
    {
        <div class="alert alert-info py-2 small mb-3">@_statusMsg</div>
    }

    @* ── Tournaments ─────────────────────────────────────────────────────────── *@
    @* Active / Ongoing *@
    @if (Ongoing().Any())
    {
        <h2 class="h5">Active / Ongoing (@Ongoing().Count)</h2>
        @TournamentTable(Ongoing())
    }

    @* Upcoming *@
    @if (Upcoming().Any())
    {
        <h2 class="h5 @(Ongoing().Any() ? "mt-3" : "")">Upcoming (@Upcoming().Count)</h2>
        @TournamentTable(Upcoming())
    }

    @if (!Ongoing().Any() && !Upcoming().Any())
    {
        <p class="text-muted small mb-3">No active or upcoming tournaments.</p>
    }

    @* Past *@
    @if (Past().Any())
    {
        <details class="mb-4">
            <summary class="text-muted mb-2" style="cursor:pointer">
                Past tournaments (@Past().Count)
            </summary>
            <div class="mt-2">@TournamentTable(Past())</div>
        </details>
    }
    @* ── Organizations ─────────────────────────────────────────────────────── *@
    <h2 class="h5 mt-2">All organizations (@_orgs.Count)</h2>
    @if (!_orgs.Any())
    {
        <p class="text-muted small">No organizations yet.</p>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-sm">
                <thead>
                    <tr><th>Name</th><th>Members</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var org in _orgs)
                    {
                        <tr>
                            <td><a href="/organizations/@org.Id">@org.Name</a></td>
                            <td class="text-muted small">@org.Members.Count</td>
                            <td>
                                @if (!_confirmDeleteOrg.Contains(org.Id))
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => _confirmDeleteOrg.Add(org.Id)"
                                            disabled="@_saving">Delete</button>
                                }
                                else
                                {
                                    <span class="text-danger small me-2">Delete "@org.Name"?</span>
                                    <button class="btn btn-sm btn-danger me-1"
                                            @onclick="() => DeleteOrg(org.Id)"
                                            disabled="@_saving">Yes</button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            @onclick="() => _confirmDeleteOrg.Remove(org.Id)">No</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _isAdmin;
    private bool _loading = true;
    private bool _saving;
    private string? _statusMsg;
    private List<User> _users = [];
    private List<Tournament> _tournaments = [];
    private List<Organization> _orgs = [];
    private HashSet<Guid> _confirmDeleteOrg = [];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        _isAdmin = authState.User.IsInRole("Admin");
        if (!_isAdmin) { _loading = false; return; }

        _users = [.. await AuthService.ListAllAsync()];
        _tournaments = [.. await TournamentService.ListAllAsync()];
        _orgs = [.. await OrgService.ListAllAsync()];
        _loading = false;
    }

    private async Task DeleteOrg(Guid orgId)
    {
        _saving = true;
        _confirmDeleteOrg.Remove(orgId);
        await OrgService.DeleteAsync(orgId);
        _orgs = [.. await OrgService.ListAllAsync()];
        _statusMsg = "Organization deleted.";
        _saving = false;
    }

    private List<Tournament> Ongoing()  => [.. _tournaments.Where(t => t.Status == TournamentStatus.InProgress).OrderBy(t => t.StartsAt)];
    private List<Tournament> Upcoming() => [.. _tournaments.Where(t => t.Status == TournamentStatus.Upcoming).OrderBy(t => t.StartsAt)];
    private List<Tournament> Past()     => [.. _tournaments.Where(t => t.Status == TournamentStatus.Ended).OrderByDescending(t => t.StartsAt)];

    private static RenderFragment TournamentTable(List<Tournament> list) => __builder =>
    {
        __builder.OpenElement(0, "div");
        __builder.AddAttribute(1, "class", "table-responsive mb-4");
        __builder.OpenElement(2, "table");
        __builder.AddAttribute(3, "class", "table table-sm");
        __builder.OpenElement(4, "thead");
        __builder.OpenElement(5, "tr");
        foreach (var h in new[] { "Title", "Organizer", "Date", "Status", "" })
        {
            __builder.OpenElement(6, "th"); __builder.AddContent(7, h); __builder.CloseElement();
        }
        __builder.CloseElement(); // tr
        __builder.CloseElement(); // thead
        __builder.OpenElement(8, "tbody");
        var seq = 9;
        foreach (var t in list)
        {
            var (label, css) = t.Status switch
            {
                TournamentStatus.InProgress => ("In Progress", "text-bg-primary"),
                TournamentStatus.Ended      => ("Ended",       "text-bg-secondary"),
                _ when t.RegistrationOpen   => ("Reg. Open",   "text-bg-success"),
                _                           => ("Reg. Closed", "text-bg-warning"),
            };
            __builder.OpenElement(seq++, "tr");
            // Title
            __builder.OpenElement(seq++, "td");
            __builder.OpenElement(seq++, "a");
            __builder.AddAttribute(seq++, "href", $"/t/{t.Slug}");
            __builder.AddContent(seq++, t.Title);
            __builder.CloseElement();
            if (t.IsPrivate)
            {
                __builder.OpenElement(seq++, "span");
                __builder.AddAttribute(seq++, "class", "badge text-bg-secondary ms-1 small");
                __builder.AddContent(seq++, "private");
                __builder.CloseElement();
            }
            if (t.IsTestEvent)
            {
                __builder.OpenElement(seq++, "span");
                __builder.AddAttribute(seq++, "class", "badge text-bg-warning ms-1 small");
                __builder.AddContent(seq++, "🧪 test");
                __builder.CloseElement();
            }
            __builder.CloseElement(); // td title
            // Organizer
            __builder.OpenElement(seq++, "td");
            __builder.AddAttribute(seq++, "class", "text-muted small");
            __builder.AddContent(seq++, t.OrganizerEmail);
            __builder.CloseElement();
            // Date
            __builder.OpenElement(seq++, "td");
            __builder.AddAttribute(seq++, "class", "text-muted small text-nowrap");
            __builder.AddContent(seq++, t.StartsAt.ToLocalTime().ToString("d MMM yyyy"));
            __builder.CloseElement();
            // Badge
            __builder.OpenElement(seq++, "td");
            __builder.OpenElement(seq++, "span");
            __builder.AddAttribute(seq++, "class", $"badge {css}");
            __builder.AddContent(seq++, label);
            __builder.CloseElement();
            __builder.CloseElement();
            // Action
            __builder.OpenElement(seq++, "td");
            __builder.OpenElement(seq++, "a");
            __builder.AddAttribute(seq++, "href", $"/t/{t.Slug}/manage");
            __builder.AddAttribute(seq++, "class", "btn btn-sm btn-outline-primary");
            __builder.AddContent(seq++, "Manage");
            __builder.CloseElement();
            __builder.CloseElement();
            __builder.CloseElement(); // tr
        }
        __builder.CloseElement(); // tbody
        __builder.CloseElement(); // table
        __builder.CloseElement(); // div
    };

    private async Task ToggleVip(User user)
    {
        _saving = true;
        _statusMsg = null;
        var newValue = !user.IsVip;
        await AuthService.SetVipAsync(user.Id, newValue);
        user.IsVip = newValue;
        _statusMsg = $"{user.Email} is {(newValue ? "now VIP $" : "no longer VIP")}.";
        _saving = false;
    }
}
