@page "/t/{Slug}/edit-registration"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Xenopairings.Models
@using Xenopairings.Services.Players
@using Xenopairings.Services.Tournaments
@using Xenopairings.Services.Auth
@using Xenopairings.Services.Organizations
@inject IPlayerService PlayerService
@inject ITournamentService TournamentService
@inject IAuthService AuthService
@inject IOrganizationService OrgService
@inject NavigationManager Nav

<PageTitle>Edit registration — Xenopairings</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_notAuthed)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Sign in required</h3>
        <p>Please <a href="/login?returnUrl=/t/@Slug/edit-registration">sign in</a> to edit your registration.</p>
    </div>
}
else if (_player is null)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Not found</h3>
        <p>You don't have a registration for this tournament.</p>
        <a href="/t/@Slug" class="btn btn-outline-primary mt-2">Back to tournament</a>
    </div>
}
else if (_withdrawn)
{
    <h1>Registration withdrawn</h1>
    <p class="text-muted">You have been removed from the tournament.</p>
    <a href="/t/@Slug" class="btn btn-outline-primary">Back to tournament</a>
}
else
{
    <h1>Edit your registration</h1>
    <p class="text-muted">Tournament: <a href="/t/@Slug">@(_tournament?.Title ?? Slug)</a></p>

    <div class="card mb-4" style="max-width:500px">
        <div class="card-body">
            <h2 class="h5 card-title">Your details</h2>

            <div class="mb-3">
                <label class="form-label fw-semibold">Name</label>
                <p class="mb-0">@_player.Name</p>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <p class="mb-0">@(_player.Email ?? "—")</p>
            </div>

            @if (_armyListLocked)
            {
                <div class="alert alert-warning py-2 mb-3 small">
                    🔒 The organizer has locked army lists — faction and army list can no longer be edited.
                </div>
            }

            <div class="mb-3">
                <label class="form-label" for="editFaction">Army / Faction</label>
                <input id="editFaction" class="form-control" @bind="_editFaction"
                       maxlength="200" placeholder="e.g. Space Marines"
                       disabled="@_armyListLocked" />
            </div>

            <div class="mb-3">
                <label class="form-label" for="editArmyList">Army list</label>
                <textarea id="editArmyList" class="form-control" rows="8"
                          @bind="_editArmyList"
                          placeholder="Paste your army list here"
                          disabled="@_armyListLocked"></textarea>
            </div>

            @if (_userOrgs.Any())
            {
                <div class="mb-3">
                    <label class="form-label" for="editOrg">
                        Representing organization <span class="text-muted">(optional)</span>
                    </label>
                    <select id="editOrg" class="form-select"
                            @onchange="e => _selectedOrgId = e.Value is string s && Guid.TryParse(s, out var g) ? g : null">
                        <option value="" selected="@(_selectedOrgId is null)">— None —</option>
                        @foreach (var org in _userOrgs)
                        {
                            <option value="@org.Id" selected="@(_selectedOrgId == org.Id)">@org.Name</option>
                        }
                    </select>
                </div>
            }

            @if (_saveSuccess)
            {
                <div class="alert alert-success py-2" role="alert">Saved!</div>
            }
            @if (!string.IsNullOrEmpty(_saveError))
            {
                <div class="alert alert-danger py-2" role="alert">@_saveError</div>
            }

            <button class="btn btn-primary btn-sm me-2" @onclick="SaveAsync"
                    disabled="@(_saving || _armyListLocked)">
                @(_saving ? "Saving…" : "Save changes")
            </button>

            <hr class="my-3" />

            @if (!_withdrawConfirm)
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="() => _withdrawConfirm = true">
                    Withdraw from tournament
                </button>
            }
            else
            {
                <p class="text-danger mb-2">Are you sure you want to withdraw?</p>
                <button class="btn btn-danger btn-sm me-2" @onclick="WithdrawAsync" disabled="@_saving">
                    @(_saving ? "Withdrawing…" : "Yes, withdraw")
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _withdrawConfirm = false">
                    Cancel
                </button>
            }
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Parameter] public string Slug { get; set; } = string.Empty;

    private Tournament? _tournament;
    private Player? _player;
    private bool _armyListLocked;
    private bool _loading = true;
    private bool _notAuthed;
    private List<Organization> _userOrgs = [];
    private Guid? _selectedOrgId;
    private bool _saving;
    private bool _saveSuccess;
    private bool _withdrawConfirm;
    private bool _withdrawn;
    private string? _saveError;
    private string? _editFaction;
    private string? _editArmyList;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value;

        if (email is null)
        {
            _notAuthed = true;
            _loading = false;
            return;
        }

        _tournament = await TournamentService.GetBySlugAsync(Slug);
        if (_tournament is not null)
        {
            var players = await PlayerService.ListByTournamentAsync(_tournament.Id);
            _player = players.FirstOrDefault(p =>
                !p.IsDropped &&
                string.Equals(p.Email, email, StringComparison.OrdinalIgnoreCase));
        }

        if (_player is not null)
        {
            _editFaction = _player.ArmyFaction;
            _editArmyList = _player.ArmyList;
            _selectedOrgId = _player.OrganizationId;
            _armyListLocked = _tournament?.ArmyListLocked ?? false;
        }

        // Load user's organizations for the org picker
        if (email is not null)
        {
            var user = await AuthService.GetByEmailAsync(email);
            if (user is not null)
                _userOrgs = [.. await OrgService.ListByUserAsync(user.Id)];
        }

        _loading = false;
    }

    private async Task SaveAsync()
    {
        if (_player is null) return;
        if (_armyListLocked) return;
        _saving = true;
        _saveSuccess = false;
        _saveError = null;
        try
        {
            await PlayerService.UpdateRegistrationAsync(_player.Id, _editFaction, _editArmyList, _selectedOrgId);
            _player.ArmyFaction = string.IsNullOrWhiteSpace(_editFaction) ? null : _editFaction.Trim();
            _player.ArmyList = string.IsNullOrWhiteSpace(_editArmyList) ? null : _editArmyList.Trim();
            _saveSuccess = true;
        }
        catch
        {
            _saveError = "Save failed. Please try again.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task WithdrawAsync()
    {
        if (_player is null) return;
        _saving = true;
        await PlayerService.DropAsync(_player.Id);
        _withdrawn = true;
        _saving = false;
    }
}
