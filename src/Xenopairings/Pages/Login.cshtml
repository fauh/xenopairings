@page "/login"
@model Xenopairings.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — Xenopairings</title>
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <main class="page-content" style="max-width:420px">
        <h1 class="mb-4">Sign in</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label" for="email">Email</label>
                <input id="email" name="email" type="email" class="form-control"
                       required autofocus value="@Model.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label" for="password">Password</label>
                <input id="password" name="password" type="password" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-primary w-100">Sign in</button>
        </form>

        <p class="mt-3 text-center text-muted">
            No account? <a href="/register">Register</a>
            &nbsp;·&nbsp; <a href="/forgot-password">Forgot password?</a>
        </p>
        <p class="text-center">
            <a href="/" class="text-muted small">Back to home</a>
        </p>
    </main>
</body>
</html>
