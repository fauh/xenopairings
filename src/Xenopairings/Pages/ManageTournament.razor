@page "/t/{Slug}/manage"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Xenopairings.Models
@using Xenopairings.Services.Tournaments
@using Xenopairings.Services.Players
@using Xenopairings.Services.Rounds
@using Xenopairings.Services.Reports
@using Xenopairings.Services.TopCut
@inject ITournamentService TournamentService
@inject IPlayerService PlayerService
@inject IRoundService RoundService
@inject IPlayerReportService PlayerReportService
@inject ITopCutService TopCutService
@inject Xenopairings.Services.Notifications.TournamentNotificationService TournamentNotifications
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Manage — Xenopairings</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_tournament is null)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔒</div>
        <h3>Not found or access denied</h3>
        <p>Check your manage link and try again.</p>
        <a href="/" class="btn btn-primary mt-3">Back to home</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/t/@_tournament.Slug">@_tournament.Title</a></li>
            <li class="breadcrumb-item active">Manage</li>
        </ol>
    </nav>

    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
        <h1>@_tournament.Title <small class="text-muted fs-6">— Manage</small></h1>
        <a href="/t/@_tournament.Slug" class="btn btn-outline-secondary btn-sm">Public view</a>
    </div>

    @* ── Tournament status + lifecycle ─────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 card-title">Event status</h2>
            <p class="card-text text-muted mb-3">
                @(_tournament.Status switch {
                    TournamentStatus.Upcoming    => "Upcoming — registration may be open or closed.",
                    TournamentStatus.InProgress  => "In Progress — rounds are being played.",
                    TournamentStatus.Ended       => "Ended — this event is complete.",
                    _                            => ""
                })
                &nbsp;·&nbsp; @_players.Count(p => !p.IsDropped) / @_tournament.MaxPlayers players
            </p>

            @* Registration toggle — only when Upcoming *@
            @if (_tournament.Status == TournamentStatus.Upcoming)
            {
                <button class="btn btn-outline-secondary btn-sm me-2"
                        @onclick="ToggleRegistration" disabled="@_saving">
                    @(_tournament.RegistrationOpen ? "Close registration" : "Open registration")
                </button>
            }

            @* Test event toggle — always available *@
            <button class="btn btn-sm me-2 @(_tournament.IsTestEvent ? "btn-warning" : "btn-outline-secondary")"
                    @onclick="ToggleTestEvent" disabled="@_saving"
                    title="@(_tournament.IsTestEvent ? "Hidden from public browse page, excluded from ELO" : "Mark as test event to hide from browse page")">
                @(_tournament.IsTestEvent ? "🧪 Test event" : "Mark as test")
            </button>

            @* Army list lock — available when event is not Ended *@
            @if (_tournament.Status != TournamentStatus.Ended)
            {
                <button class="btn btn-sm me-2 @(_tournament.ArmyListLocked ? "btn-warning" : "btn-outline-secondary")"
                        @onclick="ToggleArmyListLock" disabled="@_saving"
                        title="@(_tournament.ArmyListLocked ? "Players cannot edit their army list" : "Players can still edit their army list")">
                    @(_tournament.ArmyListLocked ? "🔒 Army lists locked" : "🔓 Lock army lists")
                </button>
            }

            @* Start event — Upcoming only *@
            @if (_tournament.Status == TournamentStatus.Upcoming)
            {
                <button class="btn btn-success btn-sm me-2"
                        @onclick="StartEvent" disabled="@_saving">
                    ▶ Start event
                </button>
            }

            @* End event — InProgress or Upcoming (organizer can end early) *@
            @if (_tournament.Status != TournamentStatus.Ended)
            {
                @if (!_confirmEnd)
                {
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => _confirmEnd = true" disabled="@_saving">
                        End event
                    </button>
                }
                else
                {
                    <span class="text-danger me-2 small">End this event? This cannot be undone.</span>
                    <button class="btn btn-danger btn-sm me-2"
                            @onclick="EndEvent" disabled="@_saving">Confirm end</button>
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="() => _confirmEnd = false">Cancel</button>
                }
            }
        </div>
    </div>

    @* ── Check-in ──────────────────────────────────────────────────────────────── *@
    @if (_tournament.CheckInEnabled && _tournament.Status != TournamentStatus.Ended)
    {
        var checkedIn = _players.Count(p => !p.IsDropped && p.IsCheckedIn);
        var total = _players.Count(p => !p.IsDropped);
        <div class="card mb-4">
            <div class="card-body">
                <h2 class="h5 card-title">
                    Check-in
                    <span class="badge text-bg-secondary ms-2 fw-normal">@checkedIn / @total</span>
                </h2>
                <p class="text-muted small mb-3">Players must check in before round 1. Only checked-in players are paired.</p>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Player</th><th>Status</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var player in _players.Where(p => !p.IsDropped).OrderBy(p => p.Name))
                            {
                                <tr>
                                    <td>@player.Name</td>
                                    <td>
                                        @if (player.IsCheckedIn)
                                        {
                                            <span class="badge text-bg-success">✓ Checked in</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">Not checked in</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm @(player.IsCheckedIn ? "btn-outline-danger" : "btn-outline-success")"
                                                @onclick="() => ToggleCheckIn(player.Id, !player.IsCheckedIn)"
                                                disabled="@_saving">
                                            @(player.IsCheckedIn ? "Undo" : "Check in")
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @* ── Player reports ─────────────────────────────────────────────────────────── *@
    @if (_reports.Any())
    {
        var unresolved = _reports.Count(r => !r.IsResolved);
        <div class="card mb-4 @(unresolved > 0 ? "border-danger" : "")">
            <div class="card-header d-flex align-items-center gap-2">
                <strong>Player reports</strong>
                @if (unresolved > 0)
                {
                    <span class="badge text-bg-danger">@unresolved unresolved</span>
                }
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr><th>Reported</th><th>Reporter</th><th>Reason</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var report in _reports)
                            {
                                <tr class="@(report.IsResolved ? "text-muted" : "")">
                                    <td>@(report.ReportedPlayer?.Name ?? "—")</td>
                                    <td>@(report.ReporterPlayer?.Name ?? "anonymous")</td>
                                    <td class="small">@report.Reason</td>
                                    <td>
                                        @if (report.IsResolved)
                                        {
                                            <span class="badge text-bg-secondary">Resolved</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">Open</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!report.IsResolved)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => ResolveReport(report.Id)"
                                                    disabled="@_saving">
                                                Resolve
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @* ── Top cut bracket ────────────────────────────────────────────────────────── *@
    @if (_tournament.TopCutSize.HasValue && _tournament.Status == TournamentStatus.InProgress)
    {
        var allSwissComplete = _rounds.Any() && _rounds.All(r => r.IsComplete);
        <div class="card mb-4">
            <div class="card-header"><strong>Top @_tournament.TopCutSize cut</strong></div>
            <div class="card-body">
                @if (!_topCutMatches.Any())
                {
                    <button class="btn btn-primary btn-sm"
                            disabled="@(!allSwissComplete || _saving)"
                            @onclick="GenerateTopCut"
                            title="@(allSwissComplete ? "" : "Complete all Swiss rounds first")">
                        Generate top-@_tournament.TopCutSize bracket
                    </button>
                    @if (!allSwissComplete)
                    {
                        <small class="text-muted ms-2">Complete all Swiss rounds first.</small>
                    }
                }
                else
                {
                    @foreach (var bracketRound in _topCutMatches.GroupBy(m => m.BracketRound).OrderBy(g => g.Key))
                    {
                        var roundLabel = bracketRound.Key == _topCutMatches.Max(m => m.BracketRound) ? "Final"
                            : bracketRound.Key == _topCutMatches.Max(m => m.BracketRound) - 1 ? "Semi-final"
                            : $"Round {bracketRound.Key}";
                        <h6 class="mt-3">@roundLabel</h6>
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr><th>Player 1</th><th>Player 2</th><th>Score</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var m in bracketRound.OrderBy(m => m.MatchNumber))
                                    {
                                        <tr>
                                            <td>
                                                @(m.Player1?.Name ?? "TBD")
                                                @if (m.WinnerId == m.Player1Id) { <span class="badge text-bg-success ms-1">Winner</span> }
                                            </td>
                                            <td>
                                                @(m.Player2Id is null ? "— (bye)" : (m.Player2?.Name ?? "TBD"))
                                                @if (m.WinnerId == m.Player2Id) { <span class="badge text-bg-success ms-1">Winner</span> }
                                            </td>
                                            <td>
                                                @if (m.IsScored && m.Player2Id is not null)
                                                {
                                                    <span>@m.Player1Score — @m.Player2Score</span>
                                                }
                                                else if (!m.IsScored && m.Player1Id is not null && m.Player2Id is not null)
                                                {
                                                    var tc = GetTopCutInput(m.Id);
                                                    <div class="d-flex gap-1 align-items-center">
                                                        <input type="number" class="form-control form-control-sm score-input" min="0" placeholder="P1"
                                                               value="@tc.p1" @oninput="e => SetTopCutScore(m.Id, true, e.Value?.ToString())" />
                                                        <span>—</span>
                                                        <input type="number" class="form-control form-control-sm score-input" min="0" placeholder="P2"
                                                               value="@tc.p2" @oninput="e => SetTopCutScore(m.Id, false, e.Value?.ToString())" />
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">bye</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!m.IsScored && m.Player1Id is not null && m.Player2Id is not null)
                                                {
                                                    var tc = GetTopCutInput(m.Id);
                                                    var canSave = tc.p1 is not null && tc.p2 is not null;
                                                    <button class="btn btn-sm btn-outline-primary"
                                                            disabled="@(!canSave || _saving)"
                                                            @onclick="() => SaveTopCutScore(m.Id)">Save</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @* ── Players ───────────────────────────────────────────────────────────────── *@
    <h2 class="h5">Players</h2>
    @if (!_players.Any())
    {
        <div class="text-muted small mb-4 fst-italic">No players registered yet.</div>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Faction</th>
                        <th>Email</th>
                        <th>Army list</th>
                        @if (_tournament.CheckInEnabled)
                        {
                            <th>Checked in</th>
                        }
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var player in _players.OrderBy(p => p.RegisteredAt))
                    {
                        <tr>
                            <td>@player.Name</td>
                            <td>@(player.ArmyFaction ?? "—")</td>
                            <td>@(player.Email ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(player.ArmyList))
                                {
                                    <span class="badge text-bg-success" title="Army list submitted">✓</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary" title="No army list">—</span>
                                }
                            </td>
                            @if (_tournament.CheckInEnabled)
                            {
                                <td>
                                    @if (player.IsCheckedIn)
                                    {
                                        <span class="badge text-bg-success">✓</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">—</span>
                                    }
                                </td>
                            }
                            <td>@(player.IsDropped ? "Dropped" : "Active")</td>
                            <td>
                                @if (!player.IsDropped && _tournament.Status != TournamentStatus.Ended)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => DropPlayer(player.Id)"
                                            disabled="@_saving">Drop</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* ── Rounds ────────────────────────────────────────────────────────────────── *@
    <h2 class="h5 mt-4">Rounds</h2>

    @if (!_rounds.Any())
    {
        <div class="text-muted small fst-italic mb-2">No rounds yet — create the first round below to generate pairings.</div>
    }

    @foreach (var round in _rounds)
    {
        var matches = _matchesByRound.GetValueOrDefault(round.Id, []);
        <div class="card mb-3">
            <div class="card-header d-flex align-items-center justify-content-between">
                <strong>Round @round.RoundNumber</strong>
                @if (!string.IsNullOrWhiteSpace(round.MissionLayout))
                {
                    <span class="text-muted small ms-2">@round.MissionLayout</span>
                }
                @if (round.IsComplete)
                {
                    <span class="badge text-bg-success ms-auto">Complete</span>
                }
                else
                {
                    <span class="badge text-bg-warning ms-auto">In progress</span>
                }
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th class="d-none d-sm-table-cell">#</th>
                                <th>Player 1</th>
                                <th>Player 2</th>
                                <th class="d-none d-md-table-cell">First turn</th>
                                <th class="d-none d-md-table-cell">Attacker</th>
                                <th>Scores</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var match in matches)
                            {
                                var isBye = match.Player2Id is null;
                                <tr>
                                    <td class="d-none d-sm-table-cell">@match.TableNumber</td>
                                    <td>@(match.Player1?.Name ?? "—")</td>
                                    <td>@(isBye ? "— (bye)" : (match.Player2?.Name ?? "—"))</td>
                                    <td class="text-muted small d-none d-md-table-cell">
                                        @if (match.Player1WentFirst == true) { <span>@(match.Player1?.Name ?? "P1")</span> }
                                        else if (match.Player1WentFirst == false) { <span>@(match.Player2?.Name ?? "P2")</span> }
                                        else if (!isBye && !match.IsScored)
                                        {
                                            <select class="form-select form-select-sm"
                                                    @onchange="e => SetFirstTurn(match.Id, e.Value?.ToString())">
                                                <option value="">—</option>
                                                <option value="p1">@(match.Player1?.Name ?? "P1")</option>
                                                <option value="p2">@(match.Player2?.Name ?? "P2")</option>
                                            </select>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                    <td class="text-muted small d-none d-md-table-cell">
                                        @if (match.Player1IsAttacker == true) { <span>@(match.Player1?.Name ?? "P1")</span> }
                                        else if (match.Player1IsAttacker == false) { <span>@(match.Player2?.Name ?? "P2")</span> }
                                        else if (!isBye && !match.IsScored)
                                        {
                                            <select class="form-select form-select-sm"
                                                    @onchange="e => SetAttacker(match.Id, e.Value?.ToString())">
                                                <option value="">—</option>
                                                <option value="p1">@(match.Player1?.Name ?? "P1")</option>
                                                <option value="p2">@(match.Player2?.Name ?? "P2")</option>
                                            </select>
                                        }
                                        else { <span>—</span> }
                                    </td>
                                    <td colspan="2">
                                        @if (isBye)
                                        {
                                            <span class="text-muted small">auto</span>
                                        }
                                        else if (match.IsScored && !_editingScores.Contains(match.Id))
                                        {
                                            @* Show breakdown if available, else totals *@
                                            @if (match.Player1PrimaryScore.HasValue)
                                            {
                                                <div class="small">
                                                    <span class="fw-semibold">@match.Player1Score — @match.Player2Score</span>
                                                    <span class="text-muted ms-1">
                                                        (P: @match.Player1PrimaryScore/@match.Player2PrimaryScore
                                                         S: @match.Player1SecondaryScore/@match.Player2SecondaryScore
                                                         BR: @(match.Player1BattleReady ? "✓" : "✗")/@(match.Player2BattleReady ? "✓" : "✗"))
                                                    </span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span>@match.Player1Score — @match.Player2Score</span>
                                            }
                                        }
                                        else if (!isBye)
                                        {
                                            @* Get or default breakdown state for this match *@
                                            @if (_scoreInputs.TryGetValue(match.Id, out var si) || true)
                                            {
                                            <ScoreEntryForm
                                                Player1Label="@(match.Player1?.Name ?? "P1")"
                                                Player2Label="@(match.Player2?.Name ?? "P2")"
                                                ScoringSystem="@(_tournament!.ScoringSystem)"
                                                P1Primary="@si.p1pri" P1PrimaryChanged="v => SetScoreField(match.Id, 0, v)"
                                                P1Secondary="@si.p1sec" P1SecondaryChanged="v => SetScoreField(match.Id, 1, v)"
                                                P1BattleReady="@si.p1br" P1BattleReadyChanged="v => SetScoreField(match.Id, 2, v)"
                                                P2Primary="@si.p2pri" P2PrimaryChanged="v => SetScoreField(match.Id, 3, v)"
                                                P2Secondary="@si.p2sec" P2SecondaryChanged="v => SetScoreField(match.Id, 4, v)"
                                                P2BattleReady="@si.p2br" P2BattleReadyChanged="v => SetScoreField(match.Id, 5, v)" />
                                            }
                                        }
                                    </td>
                                    <td>
                                        @if (!match.IsScored && !isBye)
                                        {
                                            var inputs = GetScoreInputs(match.Id);
                                            var canSave = inputs.p1 is not null && inputs.p2 is not null;
                                            <button class="btn btn-sm btn-outline-primary"
                                                    disabled="@(!canSave || _saving)"
                                                    @onclick="() => SaveScore(match.Id)">
                                                Save
                                            </button>
                                        }
                                        else if (match.IsScored && !isBye && _editingScores.Contains(match.Id))
                                        {
                                            var inputs = GetScoreInputs(match.Id);
                                            var canSave = inputs.p1 is not null && inputs.p2 is not null;
                                            <button class="btn btn-sm btn-primary me-1"
                                                    disabled="@(!canSave || _saving)"
                                                    @onclick="() => SaveEditedScore(match.Id)">
                                                Update
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => CancelEditScore(match.Id)">
                                                Cancel
                                            </button>
                                        }
                                        else if (match.IsScored && !isBye)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="() => StartEditScore(match.Id, match.Player1Score, match.Player2Score)"
                                                    disabled="@_saving"
                                                    title="Edit score">
                                                ✏
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!round.IsComplete)
                {
                    var allScored = matches.All(m => m.IsScored);
                    var anyScored = matches.Any(m => m.IsScored && m.Player2Id != null);
                    <div class="card-footer d-flex flex-wrap gap-2 align-items-center">
                        <button class="btn btn-sm btn-success"
                                disabled="@(!allScored || _saving)"
                                @onclick="() => CompleteRound(round.Id)"
                                title="@(allScored ? "" : "Enter all scores first")">
                            Complete round @round.RoundNumber
                        </button>

                        @if (!anyScored)
                        {
                            @* Re-pair random *@
                            @if (!_confirmRepair.Contains(round.Id))
                            {
                                <button class="btn btn-sm btn-outline-warning"
                                        @onclick="() => _confirmRepair.Add(round.Id)"
                                        disabled="@_saving">
                                    🔀 Re-pair randomly
                                </button>
                            }
                            else
                            {
                                <span class="text-warning small">Re-pair? All pairings will be regenerated.</span>
                                <button class="btn btn-sm btn-warning me-1"
                                        @onclick="() => RepairRandom(round.Id)" disabled="@_saving">Yes, re-pair</button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => _confirmRepair.Remove(round.Id)">Cancel</button>
                            }

                            @* Manual pairing *@
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => ToggleManualPairing(round.Id)"
                                    disabled="@_saving">
                                @(_manualRoundId == round.Id ? "✕ Cancel manual pairing" : "✏ Manual pairing")
                            </button>
                        }

                        @if (!allScored && !anyScored && _manualRoundId == round.Id) { @* spacer *@ }
                        else if (!allScored) { <small class="text-muted">Enter all scores to complete.</small> }
                    </div>

                    @* Manual pairing panel *@
                    @if (_manualRoundId == round.Id)
                    {
                        <div class="card-body border-top">
                            <h6 class="mb-3">Manual pairing — assign players to tables</h6>
                            @if (!string.IsNullOrEmpty(_manualError))
                            {
                                <div class="alert alert-danger py-2 small mb-3">@_manualError</div>
                            }
                            @for (var ti = 0; ti < _manualPairings.Count; ti++)
                            {
                                var idx = ti;
                                var pair = _manualPairings[idx];
                                var activePlayers = _players.Where(p => !p.IsDropped).ToList();
                                <div class="row g-2 align-items-center mb-2">
                                    <div class="col-auto">
                                        <span class="text-muted small">Table @(idx + 1)</span>
                                    </div>
                                    <div class="col">
                                        <select class="form-select form-select-sm"
                                                @onchange="e => SetManualPlayer(idx, true, e.Value?.ToString())">
                                            <option value="">— Player 1 —</option>
                                            @foreach (var p in activePlayers)
                                            {
                                                <option value="@p.Id" selected="@(p.Id == pair.p1)">@p.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-auto text-muted">vs</div>
                                    <div class="col">
                                        <select class="form-select form-select-sm"
                                                @onchange="e => SetManualPlayer(idx, false, e.Value?.ToString())">
                                            <option value="">— Bye —</option>
                                            @foreach (var p in activePlayers)
                                            {
                                                <option value="@p.Id" selected="@(p.Id == pair.p2)">@p.Name</option>
                                            }
                                        </select>
                                    </div>
                                    @if (idx > 0)
                                    {
                                        <div class="col-auto">
                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => RemoveManualRow(idx)">✕</button>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="mt-2 d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="AddManualRow">+ Add table</button>
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => ConfirmManualPairing(round.Id)"
                                        disabled="@_saving">
                                    Confirm pairings
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }

    @* ── Create next round ─────────────────────────────────────────────────────── *@
    @if (!_rounds.Any() || _rounds.Last().IsComplete)
    {
        @if ((_rounds.Count + 1) <= _tournament.NumberOfRounds
            && _players.Count(p => !p.IsDropped) >= 2
            && _tournament.Status != TournamentStatus.Ended)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="h6 card-title mb-3">Create Round @(_rounds.Count + 1)</h3>
                    <div class="mb-3" style="max-width:420px">
                        <label class="form-label" for="missionLayout">Mission layout <span class="text-muted">(optional)</span></label>
                        <input id="missionLayout" class="form-control" @bind="_newMissionLayout"
                               placeholder="e.g. Priority Target — Sweep and Clear" maxlength="300" />
                        <div class="form-text">Shown to players on the public page.</div>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="CreateRound" disabled="@_saving">
                        @(_saving ? "Generating…" : $"Generate pairings for Round {_rounds.Count + 1}")
                    </button>
                </div>
            </div>
        }
        else if (_rounds.Count >= _tournament.NumberOfRounds && _rounds.Any())
        {
            <div class="alert alert-success">
                All @_tournament.NumberOfRounds rounds complete. <a href="/t/@_tournament.Slug">View final standings →</a>
            </div>
        }
        else if (_players.Count(p => !p.IsDropped) < 2)
        {
            <p class="text-muted">At least 2 active players are required to create a round.</p>
        }
    }

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="alert alert-info mt-3" role="alert">@_statusMessage</div>
    }
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">@_errorMessage</div>
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Parameter] public string Slug { get; set; } = string.Empty;

    private Tournament? _tournament;
    private List<Player> _players = [];
    private List<Round> _rounds = [];
    private Dictionary<Guid, List<Match>> _matchesByRound = [];
    // Transient score-input state: matchId → (p1Primary, p1Secondary, p1BR, p2Primary, p2Secondary, p2BR)
    private Dictionary<Guid, (int? p1pri, int? p1sec, bool p1br, int? p2pri, int? p2sec, bool p2br)> _scoreInputs = [];

    // Legacy accessor shape kept for display; actual entry now uses breakdown
    private (int? p1, int? p2) GetScoreInputs(Guid matchId)
    {
        if (!_scoreInputs.TryGetValue(matchId, out var v)) return (null, null);
        var t1 = v.p1pri.HasValue && v.p1sec.HasValue
            ? Xenopairings.Services.Rounds.ScoreCalculator.ComputeTotal(v.p1pri.Value, v.p1sec.Value, v.p1br)
            : (int?)null;
        var t2 = v.p2pri.HasValue && v.p2sec.HasValue
            ? Xenopairings.Services.Rounds.ScoreCalculator.ComputeTotal(v.p2pri.Value, v.p2sec.Value, v.p2br)
            : (int?)null;
        return (t1, t2);
    }
    // First-turn and attacker pending selections before the score is saved
    private Dictionary<Guid, bool?> _firstTurnInputs = [];
    private Dictionary<Guid, bool?> _attackerInputs = [];
    // Matches whose scores are currently being edited (in completed rounds)
    private HashSet<Guid> _editingScores = [];
    private bool _loading = true;
    private bool _saving;
    private bool _confirmEnd;
    private List<PlayerReport> _reports = [];
    private List<TopCutMatch> _topCutMatches = [];
    private Dictionary<Guid, (int? p1, int? p2)> _topCutInputs = [];
    private HashSet<Guid> _confirmRepair = [];
    // Manual pairing state
    private Guid? _manualRoundId;
    private List<(Guid? p1, Guid? p2)> _manualPairings = [];
    private string? _manualError;
    private string? _statusMessage;
    private string? _errorMessage;
    private string? _newMissionLayout;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var email = authState.User.FindFirst(ClaimTypes.Email)?.Value;

        if (email is null)
        {
            Nav.NavigateTo($"/login?returnUrl=/t/{Slug}/manage", forceLoad: true);
            return;
        }

        var isAdmin = authState.User.IsInRole("Admin");
        var candidate = await TournamentService.GetBySlugAsync(Slug);
        if (candidate is not null &&
            (isAdmin || string.Equals(candidate.OrganizerEmail, email, StringComparison.OrdinalIgnoreCase)))
        {
            _tournament = candidate;
            await LoadAllAsync();
        }

        _loading = false;
    }

    private async Task LoadAllAsync()
    {
        _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
        _rounds = [.. await RoundService.ListByTournamentAsync(_tournament!.Id)];
        _reports = [.. await PlayerReportService.ListByTournamentAsync(_tournament!.Id)];
        _topCutMatches = [.. await TopCutService.GetBracketAsync(_tournament!.Id)];
        _matchesByRound = [];
        foreach (var round in _rounds)
        {
            var matches = await RoundService.GetMatchesAsync(round.Id);
            _matchesByRound[round.Id] = [.. matches];
        }
    }

    private async Task ToggleCheckIn(Guid playerId, bool checkedIn)
    {
        _saving = true;
        await PlayerService.SetCheckInAsync(playerId, checkedIn);
        _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
        _saving = false;
    }

    private async Task ResolveReport(Guid reportId)
    {
        _saving = true;
        await PlayerReportService.ResolveAsync(reportId, null);
        _reports = [.. await PlayerReportService.ListByTournamentAsync(_tournament!.Id)];
        _saving = false;
    }

    private (int? p1, int? p2) GetTopCutInput(Guid matchId)
    {
        _topCutInputs.TryGetValue(matchId, out var v);
        return v;
    }

    private void SetTopCutScore(Guid matchId, bool isP1, string? raw)
    {
        _topCutInputs.TryGetValue(matchId, out var current);
        var parsed = int.TryParse(raw, out var n) ? (int?)n : null;
        _topCutInputs[matchId] = isP1 ? (parsed, current.p2) : (current.p1, parsed);
    }

    private async Task SaveTopCutScore(Guid matchId)
    {
        if (!_topCutInputs.TryGetValue(matchId, out var inputs)) return;
        if (inputs.p1 is null || inputs.p2 is null) return;
        _saving = true;
        _errorMessage = null;
        try
        {
            await TopCutService.EnterTopCutResultAsync(matchId, inputs.p1.Value, inputs.p2.Value);
            _topCutInputs.Remove(matchId);
            _topCutMatches = [.. await TopCutService.GetBracketAsync(_tournament!.Id)];
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private async Task GenerateTopCut()
    {
        _saving = true;
        _errorMessage = null;
        try
        {
            await TopCutService.GenerateBracketAsync(_tournament!.Id);
            _topCutMatches = [.. await TopCutService.GetBracketAsync(_tournament!.Id)];
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private async Task RepairRandom(Guid roundId)
    {
        _saving = true;
        _confirmRepair.Remove(roundId);
        _errorMessage = null;
        try
        {
            await RoundService.RepairRandomAsync(roundId);
            await LoadAllAsync();
            _statusMessage = "Round re-paired randomly.";
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private void ToggleManualPairing(Guid roundId)
    {
        if (_manualRoundId == roundId)
        {
            _manualRoundId = null;
            _manualPairings = [];
            _manualError = null;
        }
        else
        {
            _manualRoundId = roundId;
            _manualError = null;
            // Pre-populate with empty slots matching the current round's match count
            var roundMatches = _matchesByRound.GetValueOrDefault(roundId, []);
            var count = Math.Max(roundMatches.Count, (_players.Count(p => !p.IsDropped) + 1) / 2);
            _manualPairings = Enumerable.Range(0, count).Select(_ => ((Guid?)null, (Guid?)null)).ToList();
        }
    }

    private void SetManualPlayer(int idx, bool isP1, string? val)
    {
        var parsed = Guid.TryParse(val, out var g) ? (Guid?)g : null;
        var (p1, p2) = _manualPairings[idx];
        _manualPairings[idx] = isP1 ? (parsed, p2) : (p1, parsed);
    }

    private void AddManualRow() =>
        _manualPairings.Add((null, null));

    private void RemoveManualRow(int idx) =>
        _manualPairings.RemoveAt(idx);

    private async Task ConfirmManualPairing(Guid roundId)
    {
        _saving = true;
        _manualError = null;
        try
        {
            var pairings = _manualPairings
                .Where(p => p.p1.HasValue)
                .Select((p, i) => (player1Id: p.p1!.Value, player2Id: p.p2, tableNumber: i + 1))
                .ToList();
            await RoundService.SetManualPairingsAsync(roundId, pairings);
            _manualRoundId = null;
            _manualPairings = [];
            await LoadAllAsync();
            _statusMessage = "Manual pairings saved.";
        }
        catch (Exception ex) { _manualError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task StartEvent()
    {
        if (_tournament is null) return;
        _saving = true;
        _errorMessage = null;
        try
        {
            await TournamentService.StartAsync(_tournament.Id);
            _tournament.Status = TournamentStatus.InProgress;
            _tournament.RegistrationOpen = false;
            _statusMessage = "Event started. Registration is now closed.";
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private async Task EndEvent()
    {
        if (_tournament is null) return;
        _saving = true;
        _confirmEnd = false;
        _errorMessage = null;
        try
        {
            await TournamentService.EndAsync(_tournament.Id);
            _tournament.Status = TournamentStatus.Ended;
            _tournament.RegistrationOpen = false;
            _statusMessage = "Event ended.";
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ToggleTestEvent()
    {
        if (_tournament is null) return;
        _saving = true;
        _errorMessage = null;
        var newValue = !_tournament.IsTestEvent;
        await TournamentService.SetTestEventAsync(_tournament.Id, newValue);
        _tournament.IsTestEvent = newValue;
        _statusMessage = newValue
            ? "Marked as test event — hidden from public browse page."
            : "Test event flag removed — now visible on browse page.";
        _saving = false;
    }

    private async Task ToggleArmyListLock()
    {
        if (_tournament is null) return;
        _saving = true;
        _errorMessage = null;
        var newValue = !_tournament.ArmyListLocked;
        await TournamentService.SetArmyListLockedAsync(_tournament.Id, newValue);
        _tournament.ArmyListLocked = newValue;
        _statusMessage = newValue ? "Army lists are now locked." : "Army lists are now unlocked.";
        _saving = false;
    }

    private async Task ToggleRegistration()
    {
        if (_tournament is null) return;
        _saving = true;
        _errorMessage = null;
        var newValue = !_tournament.RegistrationOpen;
        await TournamentService.SetRegistrationOpenAsync(_tournament.Id, newValue);
        _tournament.RegistrationOpen = newValue;
        _statusMessage = $"Registration is now {(newValue ? "open" : "closed")}.";
        _saving = false;
    }

    private async Task DropPlayer(Guid playerId)
    {
        _saving = true;
        _errorMessage = null;
        await PlayerService.DropAsync(playerId);
        _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
        _saving = false;
    }

    private async Task CreateRound()
    {
        if (_tournament is null) return;
        _saving = true;
        _errorMessage = null;
        _statusMessage = null;
        try
        {
            await RoundService.CreateWithPairingsAsync(_tournament.Id, _newMissionLayout);
            _newMissionLayout = null;
            await LoadAllAsync();
            _statusMessage = $"Round {_rounds.Count} created with pairings.";
            await TournamentNotifications.NotifyRoundStartedAsync(_tournament.Id, _rounds.Count);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // field: 0=p1pri 1=p1sec 2=p1br(bool) 3=p2pri 4=p2sec 5=p2br(bool)
    private void SetScoreField(Guid matchId, int field, object? value)
    {
        _scoreInputs.TryGetValue(matchId, out var cur);
        if (cur == default) cur = (null, null, true, null, null, true);
        _scoreInputs[matchId] = field switch
        {
            0 => (value as int?, cur.p1sec, cur.p1br, cur.p2pri, cur.p2sec, cur.p2br),
            1 => (cur.p1pri, value as int?, cur.p1br, cur.p2pri, cur.p2sec, cur.p2br),
            2 => (cur.p1pri, cur.p1sec, value is bool b1 && b1, cur.p2pri, cur.p2sec, cur.p2br),
            3 => (cur.p1pri, cur.p1sec, cur.p1br, value as int?, cur.p2sec, cur.p2br),
            4 => (cur.p1pri, cur.p1sec, cur.p1br, cur.p2pri, value as int?, cur.p2br),
            5 => (cur.p1pri, cur.p1sec, cur.p1br, cur.p2pri, cur.p2sec, value is bool b2 && b2),
            _ => cur,
        };
    }

    private void SetScore(Guid matchId, bool isP1, string? raw)
    {
        // Legacy helper — not called now that ScoreEntryForm is used
        var parsed = int.TryParse(raw, out var n) ? (int?)n : null;
        SetScoreField(matchId, isP1 ? 0 : 3, parsed);
    }

    private void StartEditScore(Guid matchId, int? p1, int? p2)
    {
        _editingScores.Add(matchId);
        // Pre-populate with existing totals — breakdown will be entered via the form
        // (p1/p2 are the old totals; we initialise breakdown as null so user fills them in)
        _scoreInputs[matchId] = (null, null, true, null, null, true);
    }

    private void CancelEditScore(Guid matchId)
    {
        _editingScores.Remove(matchId);
        _scoreInputs.Remove(matchId);
    }

    private async Task SaveEditedScore(Guid matchId)
    {
        if (!_scoreInputs.TryGetValue(matchId, out var inputs)) return;
        var totals = GetScoreInputs(matchId);
        if (totals.p1 is null || totals.p2 is null) return;

        _firstTurnInputs.TryGetValue(matchId, out var p1WentFirst);
        _attackerInputs.TryGetValue(matchId, out var p1IsAttacker);

        _saving = true;
        _errorMessage = null;
        try
        {
            if (inputs.p1pri.HasValue && inputs.p1sec.HasValue &&
                inputs.p2pri.HasValue && inputs.p2sec.HasValue)
            {
                await RoundService.EnterScoreBreakdownAsync(
                    matchId,
                    inputs.p1pri.Value, inputs.p1sec.Value, inputs.p1br,
                    inputs.p2pri.Value, inputs.p2sec.Value, inputs.p2br,
                    player1IsAttacker: p1IsAttacker,
                    player1WentFirst:  p1WentFirst);
            }
            else
            {
                await RoundService.UpdateScoreAsync(
                    matchId, totals.p1.Value, totals.p2.Value,
                    player1IsAttacker: p1IsAttacker,
                    player1WentFirst:  p1WentFirst);
            }
            _editingScores.Remove(matchId);
            _scoreInputs.Remove(matchId);
            _firstTurnInputs.Remove(matchId);
            _attackerInputs.Remove(matchId);
            foreach (var round in _rounds)
            {
                var freshMatches = await RoundService.GetMatchesAsync(round.Id);
                _matchesByRound[round.Id] = [.. freshMatches];
            }
            _statusMessage = "Score updated.";
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _saving = false; }
    }

    private void SetFirstTurn(Guid matchId, string? value)
    {
        _firstTurnInputs[matchId] = value == "p1" ? true : value == "p2" ? false : null;
    }

    private void SetAttacker(Guid matchId, string? value)
    {
        _attackerInputs[matchId] = value == "p1" ? true : value == "p2" ? false : null;
    }

    private async Task SaveScore(Guid matchId)
    {
        if (!_scoreInputs.TryGetValue(matchId, out var inputs)) return;
        if (inputs.p1pri is null || inputs.p1sec is null ||
            inputs.p2pri is null || inputs.p2sec is null) return;

        _firstTurnInputs.TryGetValue(matchId, out var p1WentFirst);
        _attackerInputs.TryGetValue(matchId, out var p1IsAttacker);

        _saving = true;
        _errorMessage = null;
        try
        {
            await RoundService.EnterScoreBreakdownAsync(
                matchId,
                inputs.p1pri.Value, inputs.p1sec.Value, inputs.p1br,
                inputs.p2pri.Value, inputs.p2sec.Value, inputs.p2br,
                player1IsAttacker: p1IsAttacker,
                player1WentFirst:  p1WentFirst);
            _scoreInputs.Remove(matchId);
            _firstTurnInputs.Remove(matchId);
            _attackerInputs.Remove(matchId);
            // Refresh the round's matches
            foreach (var round in _rounds)
            {
                var freshMatches = await RoundService.GetMatchesAsync(round.Id);
                _matchesByRound[round.Id] = [.. freshMatches];
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task CompleteRound(Guid roundId)
    {
        _saving = true;
        _errorMessage = null;
        try
        {
            await RoundService.CompleteRoundAsync(roundId);
            await LoadAllAsync();
            var round = _rounds.FirstOrDefault(r => r.Id == roundId);
            _statusMessage = round is not null ? $"Round {round.RoundNumber} marked complete." : "Round completed.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
