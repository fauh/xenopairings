@page "/new"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Xenopairings.Models
@using Xenopairings.Services.Tournaments
@inject ITournamentService TournamentService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>New tournament — Xenopairings</PageTitle>

@if (_email is null && !_loading)
{
    <div class="alert alert-warning">
        You need to <a href="/login">sign in</a> to create a tournament.
    </div>
}
else
{

<h1>Create a tournament</h1>

<EditForm Model="@model" OnValidSubmit="HandleSubmit" style="max-width:600px">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="title">Tournament title <span class="text-danger">*</span></label>
        <InputText id="title" class="form-control" @bind-Value="model.Title" placeholder="e.g. GT Season 4" />
        <ValidationMessage For="@(() => model.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="description">Description</label>
        <InputTextArea id="description" class="form-control" @bind-Value="model.Description" rows="3"
            placeholder="Optional details about the tournament" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="startsAt">Tournament date &amp; time <span class="text-danger">*</span></label>
        <InputDate id="startsAt" class="form-control" Type="InputDateType.DateTimeLocal"
            @bind-Value="model.StartsAt" />
        <ValidationMessage For="@(() => model.StartsAt)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="timezone">Your time zone</label>
        <input id="timezone" class="form-control" type="text" value="@model.TimeZoneId" readonly
            title="Detected from your browser" />
        <div class="form-text">Detected from your browser.</div>
    </div>

    <div class="mb-3">
        <label class="form-label" for="numberOfRounds">Number of rounds <span class="text-danger">*</span></label>
        <InputNumber id="numberOfRounds" class="form-control" @bind-Value="model.NumberOfRounds" min="1" max="9" />
        <ValidationMessage For="@(() => model.NumberOfRounds)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="maxPlayers">Max players <span class="text-danger">*</span></label>
        <InputNumber id="maxPlayers" class="form-control" @bind-Value="model.MaxPlayers" min="2" />
        <ValidationMessage For="@(() => model.MaxPlayers)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="organizerName">Your name <span class="text-danger">*</span></label>
        <InputText id="organizerName" class="form-control" @bind-Value="model.OrganizerName" />
        <ValidationMessage For="@(() => model.OrganizerName)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Your email</label>
        <input class="form-control" type="email" value="@_email" readonly />
        <div class="form-text">Your account email — used to identify you as the organizer.</div>
    </div>

    <div class="mb-3">
        <label class="form-label">Scoring system <span class="text-danger">*</span></label>
        <InputRadioGroup @bind-Value="model.ScoringSystem">
            <div class="form-check">
                <InputRadio class="form-check-input" id="scoring-gw" Value="@ScoringSystem.Gw" />
                <label class="form-check-label" for="scoring-gw">GW — straight battle points</label>
            </div>
            <div class="form-check">
                <InputRadio class="form-check-input" id="scoring-wtc" Value="@ScoringSystem.Wtc" />
                <label class="form-check-label" for="scoring-wtc">WTC — 0–20 game points via differential</label>
            </div>
        </InputRadioGroup>
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="isTeamEvent" class="form-check-input" @bind-Value="model.IsTeamEvent" />
        <label class="form-check-label" for="isTeamEvent">Team event</label>
        <div class="form-text">Players form teams and compete as a group.</div>
    </div>

    @if (model.IsTeamEvent)
    {
        <div class="mb-3">
            <label class="form-label" for="teamSize">Players per team <span class="text-danger">*</span></label>
            <InputNumber id="teamSize" class="form-control" @bind-Value="model.TeamSize" min="2" max="10" style="max-width:120px" />
            <div class="form-text">All teams must have exactly this many players before rounds can start.</div>
        </div>
    }

    @* ── Tiebreakers (drag-and-drop ordered) ────────────────────────────────── *@
    <div class="mb-3">
        <label class="form-label">Tiebreakers <span class="text-muted small">(drag to reorder; uncheck to remove)</span></label>
        <ul class="list-group" style="max-width:420px">
            @foreach (var tb in model.ActiveTiebreakers)
            {
                <li class="list-group-item d-flex align-items-center gap-2 py-2"
                    draggable="true"
                    @ondragstart="() => _dragTb = tb"
                    @ondragover:preventDefault
                    @ondrop="() => DropTiebreaker(tb)"
                    style="cursor:grab">
                    <span class="text-muted">≡</span>
                    <span class="flex-grow-1 small">@TiebreakerLabel(tb)</span>
                    <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1"
                            @onclick="() => RemoveTiebreaker(tb)">✕</button>
                </li>
            }
        </ul>
        @{
            var available = model.AvailableTiebreakers.Except(model.ActiveTiebreakers).ToList();
        }
        @if (available.Any())
        {
            <div class="mt-2 d-flex flex-wrap gap-1">
                @foreach (var tb in available)
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            @onclick="() => AddTiebreaker(tb)">
                        + @TiebreakerLabel(tb)
                    </button>
                }
            </div>
        }
    </div>

    @* ── Top cut ──────────────────────────────────────────────────────────────── *@
    <div class="mb-3">
        <label class="form-label" for="topCutSize">Top cut</label>
        <select id="topCutSize" class="form-select" style="max-width:160px"
                @onchange="e => model.TopCutSize = e.Value is string s && int.TryParse(s, out var n) && n > 0 ? n : null">
            <option value="0" selected="@(model.TopCutSize is null)">None</option>
            @foreach (var size in new[] { 4, 8, 16, 32 })
            {
                <option value="@size" selected="@(model.TopCutSize == size)">Top @size</option>
            }
        </select>
        <div class="form-text">Single-elimination bracket after Swiss rounds.</div>
    </div>

    @* ── Check-in ─────────────────────────────────────────────────────────────── *@
    <div class="mb-3 form-check">
        <InputCheckbox id="checkInEnabled" class="form-check-input" @bind-Value="model.CheckInEnabled" />
        <label class="form-check-label" for="checkInEnabled">Require player check-in</label>
        <div class="form-text">Only checked-in players are included in round 1 pairings.</div>
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="isPrivate" class="form-check-input" @bind-Value="model.IsPrivate" />
        <label class="form-check-label" for="isPrivate">Private tournament (link-only)</label>
        <div class="form-text">When ticked, this tournament won't appear in public lists.</div>
    </div>

    <div class="mb-3 form-check">
        <InputCheckbox id="registrationOpen" class="form-check-input" @bind-Value="model.RegistrationOpen" />
        <label class="form-check-label" for="registrationOpen">Registration open</label>
        <div class="form-text">Uncheck to create the tournament without allowing sign-ups yet.</div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">@errorMessage</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
        @(isSubmitting ? "Creating…" : "Create tournament")
    </button>
</EditForm>

}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private readonly FormModel model = new();
    private string? errorMessage;
    private bool isSubmitting;
    private string? _email;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        _email = authState.User.FindFirst(ClaimTypes.Email)?.Value;
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var tz = await JS.InvokeAsync<string>("eval", "Intl.DateTimeFormat().resolvedOptions().timeZone");
            if (!string.IsNullOrWhiteSpace(tz))
                model.TimeZoneId = tz;
        }
        catch { }
        StateHasChanged();
    }

    // ── Tiebreaker drag-and-drop ──────────────────────────────────────────────
    private TiebreakerType? _dragTb;

    private void DropTiebreaker(TiebreakerType target)
    {
        if (_dragTb is null || _dragTb == target) return;
        var list = model.ActiveTiebreakers;
        var fromIdx = list.IndexOf(_dragTb.Value);
        var toIdx   = list.IndexOf(target);
        if (fromIdx < 0 || toIdx < 0) return;
        list.RemoveAt(fromIdx);
        list.Insert(toIdx, _dragTb.Value);
        _dragTb = null;
    }

    private void RemoveTiebreaker(TiebreakerType tb) => model.ActiveTiebreakers.Remove(tb);
    private void AddTiebreaker(TiebreakerType tb)    => model.ActiveTiebreakers.Add(tb);

    private static string TiebreakerLabel(TiebreakerType tb) => tb switch
    {
        TiebreakerType.Points                     => "Points (total BPs)",
        TiebreakerType.StrengthOfSchedule         => "Strength of Schedule",
        TiebreakerType.ExtendedStrengthOfSchedule => "Extended SOS",
        TiebreakerType.HeadToHead                 => "Head-to-Head",
        TiebreakerType.Random                     => "Random",
        _                                          => tb.ToString(),
    };

    private async Task HandleSubmit()
    {
        if (_email is null) return;
        isSubmitting = true;
        errorMessage = null;
        try
        {
            var tournament = await TournamentService.CreateAsync(new CreateTournamentRequest(
                Title: model.Title,
                Description: model.Description,
                StartsAt: model.StartsAt,
                TimeZoneId: model.TimeZoneId,
                NumberOfRounds: model.NumberOfRounds,
                MaxPlayers: model.MaxPlayers,
                OrganizerName: model.OrganizerName,
                OrganizerEmail: _email,
                IsPrivate: model.IsPrivate,
                RegistrationOpen: model.RegistrationOpen,
                ScoringSystem: model.ScoringSystem,
                IsTeamEvent: model.IsTeamEvent,
                TeamSize: model.IsTeamEvent ? model.TeamSize : null,
                TiebreakersJson: model.TiebreakersJson,
                TopCutSize: model.TopCutSize,
                CheckInEnabled: model.CheckInEnabled
            ));
            Nav.NavigateTo($"/created/{tournament.Id}");
        }
        catch
        {
            errorMessage = "Something went wrong creating the tournament. Please try again.";
            isSubmitting = false;
        }
    }

    private sealed class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Title is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Title { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.MaxLength(2000)]
        public string? Description { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Tournament date is required.")]
        public DateTime StartsAt { get; set; } = DateTime.Today.AddDays(14).AddHours(9);

        public string TimeZoneId { get; set; } = "UTC";

        [System.ComponentModel.DataAnnotations.Range(1, 9, ErrorMessage = "Rounds must be between 1 and 9.")]
        public int NumberOfRounds { get; set; } = 5;

        [System.ComponentModel.DataAnnotations.Range(2, 256, ErrorMessage = "Max players must be at least 2.")]
        public int MaxPlayers { get; set; } = 16;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Your name is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string OrganizerName { get; set; } = string.Empty;

        public ScoringSystem ScoringSystem { get; set; } = ScoringSystem.Gw;
        public bool IsTeamEvent { get; set; }
        public int TeamSize { get; set; } = 3;
        public bool IsPrivate { get; set; }
        public bool RegistrationOpen { get; set; } = true;

        // Phase 3b
        public List<TiebreakerType> ActiveTiebreakers { get; set; } =
            [TiebreakerType.Points, TiebreakerType.StrengthOfSchedule, TiebreakerType.Random];
        public IReadOnlyList<TiebreakerType> AvailableTiebreakers { get; } =
            [TiebreakerType.Points, TiebreakerType.StrengthOfSchedule,
             TiebreakerType.ExtendedStrengthOfSchedule, TiebreakerType.HeadToHead, TiebreakerType.Random];
        public int? TopCutSize { get; set; }
        public bool CheckInEnabled { get; set; }

        public string TiebreakersJson =>
            Tournament.SerializeTiebreakers(ActiveTiebreakers);
    }
}
