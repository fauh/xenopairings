@page
@model Xenopairings.Pages.ResetPasswordModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset password — Xenopairings</title>
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <main class="page-content" style="max-width:420px">
        <h1 class="mb-4">Reset password</h1>

        @if (Model.Success)
        {
            <div class="alert alert-success">
                Password updated. <a href="/login">Sign in</a> with your new password.
            </div>
        }
        else if (Model.InvalidToken)
        {
            <div class="alert alert-danger">
                This reset link is invalid or has expired.
                <a href="/forgot-password">Request a new one →</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@Model.Token" />
                <div class="mb-3">
                    <label class="form-label" for="password">New password</label>
                    <input id="password" name="password" type="password" class="form-control"
                           required minlength="8" autofocus />
                    <div class="form-text">Minimum 8 characters.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="confirm">Confirm password</label>
                    <input id="confirm" name="confirm" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Set new password</button>
            </form>
        }
    </main>
</body>
</html>
