@page "/created/{TournamentId:guid}"
@using Xenopairings.Models
@using Xenopairings.Services.Tournaments
@inject ITournamentService TournamentService
@inject NavigationManager Nav

<PageTitle>Tournament created — Xenopairings</PageTitle>

@if (_tournament is null)
{
    <LoadingSpinner />
}
else
{
    <h1>Tournament created!</h1>

    <div class="card mb-4" style="max-width:560px">
        <div class="card-body">
            <h5 class="card-title">@_tournament.Title</h5>
            <p class="card-text text-muted">
                @_tournament.NumberOfRounds rounds · up to @_tournament.MaxPlayers players
            </p>
        </div>
    </div>

    <a href="/t/@_tournament.Slug" class="btn btn-outline-primary me-2">View public page</a>
    <a href="/t/@_tournament.Slug/manage" class="btn btn-primary">Manage tournament</a>

    <p class="mt-3 text-muted small">
        Find this tournament anytime from your <a href="/dashboard">dashboard</a>.
    </p>
}

@code {
    [Parameter] public Guid TournamentId { get; set; }

    private Tournament? _tournament;

    protected override async Task OnInitializedAsync()
    {
        _tournament = await TournamentService.GetByIdAsync(TournamentId);
        if (_tournament is null)
            Nav.NavigateTo("/");
    }
}
