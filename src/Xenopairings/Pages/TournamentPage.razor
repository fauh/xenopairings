@page "/t/{Slug}"
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Xenopairings.Models
@using Xenopairings.Services.Tournaments
@using Xenopairings.Services.Players
@using Xenopairings.Services.Rounds
@using Xenopairings.Services.Standings
@using Xenopairings.Services.Pairings
@using Xenopairings.Services.Elo
@using Xenopairings.Services.Auth
@using Xenopairings.Services.Organizations
@using Xenopairings.Services.Reports
@using Xenopairings.Services.Teams
@using Xenopairings.Services.Organizations
@inject ITournamentService TournamentService
@inject IPlayerService PlayerService
@inject IRoundService RoundService
@inject StandingsService StandingsService
@inject IEloService EloService
@inject IAuthService AuthService
@inject IOrganizationService OrgService
@inject IPlayerReportService PlayerReportService
@inject ITeamService TeamService
@inject NavigationManager Nav

<PageTitle>@(_tournament?.Title ?? "Tournament") — Xenopairings</PageTitle>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_tournament is null)
{
    <div class="empty-state">
        <div class="empty-state-icon">🎲</div>
        <h3>Tournament not found</h3>
        <p>This tournament doesn't exist or may have been removed.</p>
        <a href="/" class="btn btn-primary mt-3">Back to home</a>
    </div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/tournaments">Tournaments</a></li>
            <li class="breadcrumb-item active">@_tournament.Title</li>
        </ol>
    </nav>

    <h1>
        @_tournament.Title
        @if (_tournament.IsTestEvent)
        {
            <span class="badge text-bg-warning ms-2 fs-6" title="Test event — not visible on the public browse page">🧪 Test</span>
        }
    </h1>

    @if (!string.IsNullOrWhiteSpace(_tournament.Description))
    {
        <p class="lead">@_tournament.Description</p>
    }

    <div class="mb-3 text-muted">
        <small>
            @_tournament.NumberOfRounds rounds ·
            @_players.Count(p => !p.IsDropped) / @_tournament.MaxPlayers players
            @if (!_tournament.RegistrationOpen)
            {
                <span> · Registration closed</span>
            }
            @if (_tournament.Status == TournamentStatus.Ended)
            {
                <span> · Tournament closed</span>
            }
        </small>
    </div>

    @* ── Team registration + management (team events) ──────────────────────────── *@
    @if (_tournament.IsTeamEvent)
    {
        @if (_myTeam is not null)
        {
            @* Member: show team info. Captain: show full management. *@
            <div class="card mb-4" style="max-width:600px">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <strong>@_myTeam.Name</strong>
                    <span class="badge text-bg-secondary">
                        @_myTeam.Players.Count(p => !p.IsDropped) / @_tournament.TeamSize players
                    </span>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(_teamError))   { <div class="alert alert-danger py-2 small">@_teamError</div> }
                    @if (!string.IsNullOrEmpty(_teamSuccess)) { <div class="alert alert-success py-2 small">@_teamSuccess</div> }

                    @* Member list *@
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var p in _myTeam.Players.Where(p => !p.IsDropped))
                        {
                            <li class="list-group-item d-flex align-items-center justify-content-between px-0">
                                <span>
                                    @p.Name
                                    @if (_myTeam.CaptainPlayerId == p.Id)
                                    {
                                        <span class="badge text-bg-warning ms-1 small">Captain</span>
                                    }
                                    @if (p.Id == _myPlayerId)
                                    {
                                        <span class="badge text-bg-primary ms-1 small">you</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(p.ArmyFaction))
                                    {
                                        <span class="text-muted small ms-2">@p.ArmyFaction</span>
                                    }
                                </span>
                                @if (_isCaptain && p.Id != _myPlayerId)
                                {
                                    <span class="d-flex gap-1">
                                        @if (_confirmRemovePlayer == p.Id)
                                        {
                                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveTeamPlayer(p.Id)" disabled="@_teamBusy">Remove</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _confirmRemovePlayer = null">Cancel</button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _editingMember = (_editingMember == p.Id ? null : p.Id)" title="Edit member">✏</button>
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => TransferCaptain(p.Id)" disabled="@_teamBusy" title="Make captain">👑</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmRemovePlayer = p.Id" title="Remove">✕</button>
                                        }
                                    </span>
                                }
                            </li>
                            @if (_isCaptain && _editingMember == p.Id)
                            {
                                <li class="list-group-item px-0 py-2">
                                    <div class="d-flex gap-2 align-items-end flex-wrap">
                                        <div>
                                            <label class="form-label small mb-1">Faction</label>
                                            <input class="form-control form-control-sm" style="width:160px"
                                                   @bind="_editMemberFaction" placeholder="e.g. Space Marines" />
                                        </div>
                                        <div class="flex-grow-1">
                                            <label class="form-label small mb-1">Army list</label>
                                            <textarea class="form-control form-control-sm" rows="2"
                                                      @bind="_editMemberArmyList" placeholder="Paste army list…"></textarea>
                                        </div>
                                        <button class="btn btn-sm btn-primary align-self-end" @onclick="() => SaveMemberEdit(p.Id)" disabled="@_teamBusy">Save</button>
                                        <button class="btn btn-sm btn-outline-secondary align-self-end" @onclick="() => _editingMember = null">Cancel</button>
                                    </div>
                                </li>
                            }
                        }
                    </ul>

                    @if (_isCaptain)
                    {
                        @* Invite link *@
                        <div class="mb-3">
                            <label class="form-label small">Invite link</label>
                            <div class="input-group input-group-sm">
                                <input class="form-control font-monospace" readonly
                                       value="@($"{Nav.BaseUri.TrimEnd('/')}/t/{Slug}/join-team?code={_myTeam.InviteToken}")" />
                                <button class="btn btn-outline-secondary" @onclick="CopyInviteLink">Copy</button>
                            </div>
                            @if (_inviteCopied) { <small class="text-success">Copied!</small> }
                        </div>

                        @* Add player manually *@
                        <details class="mb-3">
                            <summary class="small text-muted" style="cursor:pointer">+ Add player manually</summary>
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                <input class="form-control form-control-sm" style="width:160px"
                                       @bind="_addName" placeholder="Name *" maxlength="200" />
                                <input class="form-control form-control-sm" style="width:200px"
                                       @bind="_addEmail" placeholder="Email (optional)" type="email" />
                                <button class="btn btn-sm btn-primary" @onclick="AddPlayerManually"
                                        disabled="@(string.IsNullOrWhiteSpace(_addName) || _teamBusy)">
                                    Add
                                </button>
                            </div>
                        </details>

                        @* Invite from organizations *@
                        @if (_userOrgs.Any())
                        {
                            <details class="mb-2">
                                <summary class="small text-muted" style="cursor:pointer">+ Invite from your organizations</summary>
                                @foreach (var org in _userOrgs)
                                {
                                    var invitable = OrgMembersNotOnTeam(org);
                                    @if (invitable.Any())
                                    {
                                        <div class="mt-2">
                                            <div class="small fw-semibold mb-1">@org.Name</div>
                                            @foreach (var member in invitable)
                                            {
                                                <div class="d-flex align-items-center justify-content-between mb-1">
                                                    <span class="small">@(member.DisplayName ?? member.Email)</span>
                                                    <button class="btn btn-sm btn-outline-primary py-0 px-2"
                                                            @onclick="() => InviteOrgMember(member.Email)"
                                                            disabled="@_teamBusy">
                                                        Add
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </details>
                        }
                    }
                </div>
            </div>
        }
        else if (_tournament.RegistrationOpen && _tournament.Status == TournamentStatus.Upcoming && _sessionEmail is not null)
        {
            @* Not on a team yet — create or join *@
            <div class="card mb-4" style="max-width:500px">
                <div class="card-body">
                    <h2 class="h5 card-title">Join this tournament</h2>
                    <p class="text-muted small">This is a team event — create a new team or join an existing one.</p>

                    @if (!string.IsNullOrEmpty(_teamError))
                    {
                        <div class="alert alert-danger py-2 small">@_teamError</div>
                    }

                    @* Create team *@
                    <div class="mb-4">
                        <label class="form-label small fw-semibold">Create a team</label>
                        <div class="input-group">
                            <input class="form-control" @bind="_newTeamName" maxlength="100"
                                   placeholder="Team name" />
                            <button class="btn btn-primary"
                                    @onclick="CreateTeam"
                                    disabled="@(string.IsNullOrWhiteSpace(_newTeamName) || _teamBusy)">
                                Create &amp; become captain
                            </button>
                        </div>
                    </div>

                    @* Join with code *@
                    <div>
                        <label class="form-label small fw-semibold">Join with invite code</label>
                        <div class="input-group">
                            <input class="form-control" @bind="_joinCode" maxlength="50"
                                   placeholder="Paste invite code" />
                            <button class="btn btn-outline-primary"
                                    @onclick="JoinWithCode"
                                    disabled="@(string.IsNullOrWhiteSpace(_joinCode) || _teamBusy)">
                                Join
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (_sessionEmail is null && _tournament.RegistrationOpen)
        {
            <p class="text-muted mb-4">
                <a href="/login?returnUrl=/t/@Slug">Sign in</a> to create or join a team.
            </p>
        }
    }

    @* ── Individual registration (non-team events only) ──────────────────────────── *@
    @if (!_tournament.IsTeamEvent && _tournament.RegistrationOpen && _tournament.Status == TournamentStatus.Upcoming && !_myRegistrationSuccess)
    {
        <div class="card mb-4" style="max-width:500px">
            <div class="card-body">
                <h2 class="h5 card-title">Register for this tournament</h2>

                @if (_sessionEmail is null)
                {
                    <p class="text-muted">
                        <a href="/login?returnUrl=/t/@Slug">Sign in</a> to register for this tournament.
                    </p>
                }
                else if (_alreadyRegistered)
                {
                    <div class="alert alert-info">
                        You're already registered. <a href="/t/@Slug/edit-registration">Edit your registration →</a>
                    </div>
                }
                else if (_registrationSuccess)
                {
                    <div class="alert alert-success" role="alert">
                        You're registered! View or edit from your <a href="/dashboard">dashboard</a>.
                    </div>
                }
                else
                {
                    <EditForm Model="@_regModel" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label" for="playerName">Name <span class="text-danger">*</span></label>
                            <InputText id="playerName" class="form-control" @bind-Value="_regModel.Name" />
                            <ValidationMessage For="@(() => _regModel.Name)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" type="email" value="@_sessionEmail" readonly />
                            <div class="form-text">Your account email.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="playerFaction">Army / Faction</label>
                            <InputText id="playerFaction" class="form-control" @bind-Value="_regModel.ArmyFaction"
                                placeholder="e.g. Space Marines" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="playerArmyList">Army list</label>
                            <InputTextArea id="playerArmyList" class="form-control" @bind-Value="_regModel.ArmyList"
                                rows="5" placeholder="Paste your army list here (optional)" />
                        </div>

                        @if (_userOrgs.Any())
                        {
                            <div class="mb-3">
                                <label class="form-label" for="regOrg">
                                    Representing organization <span class="text-muted">(optional)</span>
                                </label>
                                <select id="regOrg" class="form-select"
                                        @onchange="e => _selectedOrgId = e.Value is string s && Guid.TryParse(s, out var g) ? g : null">
                                    <option value="">— None —</option>
                                    @foreach (var org in _userOrgs)
                                    {
                                        <option value="@org.Id" selected="@(org.Id == _selectedOrgId)">@org.Name</option>
                                    }
                                </select>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_regError))
                        {
                            <div class="alert alert-danger" role="alert">@_regError</div>
                        }

                        <button type="submit" class="btn btn-primary" disabled="@_regSubmitting">
                            @(_regSubmitting ? "Registering…" : "Register")
                        </button>
                    </EditForm>
                }
            </div>
        </div>
    }

    @* ── Round navigation ────────────────────────────────────────────────────────── *@
    @if (_allRounds.Count > 0)
    {
        <div class="d-flex gap-1 mt-4 flex-wrap">
            @foreach (var (r, _) in _allRounds)
            {
                var isCurrent = r.Id == _currentRound?.Id;
                <a href="/t/@_tournament!.Slug/round/@(r.RoundNumber)"
                   class="btn btn-sm @(isCurrent ? "btn-primary" : "btn-outline-secondary")">
                    R@(r.RoundNumber)
                </a>
            }
        </div>
    }

    @* ── Current round ───────────────────────────────────────────────────────────── *@
    @if (_currentRound is not null)
    {
        var matches = _currentMatches;
        var myMatch = _myCurrentMatch;

        <div class="mt-4">
            <h2 class="h5 d-flex align-items-center gap-2">
                <a href="/t/@_tournament!.Slug/round/@_currentRound.RoundNumber"
                   class="text-decoration-none text-body">
                    Round @_currentRound.RoundNumber
                </a>
                @if (!string.IsNullOrWhiteSpace(_currentRound.MissionLayout))
                {
                    <small class="text-muted fw-normal">@_currentRound.MissionLayout</small>
                }
                @if (_currentRound.IsComplete)
                {
                    <span class="badge text-bg-success">Complete</span>
                }
                else
                {
                    <span class="badge text-bg-warning">In progress</span>
                }
                <a href="/t/@_tournament!.Slug/round/@_currentRound.RoundNumber"
                   class="btn btn-outline-secondary btn-sm ms-auto">View →</a>
            </h2>

            @* Submit form — unscored match in the current round *@
            @if (!_currentRound.IsComplete && myMatch is not null && !myMatch.IsScored && myMatch.Player2Id is not null)
            {
                var opponent = myMatch.Player1Id == _myPlayerId ? myMatch.Player2 : myMatch.Player1;
                <div class="card mb-3 border-primary" style="max-width:480px">
                    <div class="card-body">
                        <h3 class="h6 card-title">Submit your result — Table @myMatch.TableNumber</h3>
                        <p class="text-muted small mb-3">vs <strong>@(opponent?.Name ?? "opponent")</strong></p>

                        <div class="row g-2 mb-3">
                            <div class="col">
                                <label class="form-label small">Your score</label>
                                <input type="number" class="form-control form-control-sm" min="0"
                                       @bind="_submitMyScore" placeholder="0" />
                            </div>
                            <div class="col">
                                <label class="form-label small">Opponent score</label>
                                <input type="number" class="form-control form-control-sm" min="0"
                                       @bind="_submitOpponentScore" placeholder="0" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">First turn</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ft"
                                       id="ft-me" @onchange="() => _submitIWentFirst = true"
                                       checked="@(_submitIWentFirst == true)" />
                                <label class="form-check-label small" for="ft-me">I went first</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="ft"
                                       id="ft-them" @onchange="() => _submitIWentFirst = false"
                                       checked="@(_submitIWentFirst == false)" />
                                <label class="form-check-label small" for="ft-them">Opponent went first</label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Role</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="role"
                                       id="role-atk" @onchange="() => _submitIWasAttacker = true"
                                       checked="@(_submitIWasAttacker == true)" />
                                <label class="form-check-label small" for="role-atk">Attacker</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="role"
                                       id="role-def" @onchange="() => _submitIWasAttacker = false"
                                       checked="@(_submitIWasAttacker == false)" />
                                <label class="form-check-label small" for="role-def">Defender</label>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_submitError))
                        {
                            <div class="alert alert-danger py-2 small">@_submitError</div>
                        }
                        @if (_submitSuccess)
                        {
                            <div class="alert alert-success py-2 small">Result submitted!</div>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="SubmitMatchResult"
                                disabled="@(_submitMyScore is null || _submitOpponentScore is null
                                            || _submitIWentFirst is null || _submitIWasAttacker is null
                                            || _submitBusy)">
                            Submit result
                        </button>
                    </div>
                </div>
            }
            else if (myMatch is not null && myMatch.IsScored)
            {
                var myScore  = myMatch.Player1Id == _myPlayerId ? myMatch.Player1Score : myMatch.Player2Score;
                var oppScore = myMatch.Player1Id == _myPlayerId ? myMatch.Player2Score : myMatch.Player1Score;
                <div class="alert alert-success mb-3 py-2 small">
                    <strong>Your result:</strong> @myScore — @oppScore
                </div>
            }

            @* Pairings — all tables, player's row first + highlighted *@
            @if (!matches.Any())
            {
                <p class="text-muted small fst-italic">No pairings generated yet.</p>
            }
            else
            {
                <div class="table-responsive mb-3">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th class="d-none d-sm-table-cell">#</th>
                                <th>Player 1</th>
                                <th>Player 2</th>
                                <th class="d-none d-md-table-cell">First</th>
                                <th class="d-none d-md-table-cell">Attacker</th>
                                <th>Result</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var match in (myMatch is not null
                                ? matches.OrderBy(m => m.Id == myMatch.Id ? 0 : 1).ThenBy(m => m.TableNumber)
                                : matches.OrderBy(m => m.TableNumber)))
                            {
                                var isMyRow = match.Id == myMatch?.Id;
                                <tr class="@(isMyRow ? "table-primary fw-semibold" : "")">
                                    <td class="d-none d-sm-table-cell">
                                        @match.TableNumber
                                        @if (isMyRow) { <span class="badge text-bg-primary ms-1 fw-normal small">you</span> }
                                    </td>
                                    <td>@PlayerNameCell(match.Player1)</td>
                                    <td>@if (match.Player2Id is null) {<span class="text-muted">— (bye)</span>} else {@PlayerNameCell(match.Player2)}</td>
                                    <td class="text-muted small fw-normal d-none d-md-table-cell">
                                        <span>@(match.Player1WentFirst == true  ? match.Player1?.Name ?? "P1"
                                               : match.Player1WentFirst == false ? match.Player2?.Name ?? "P2"
                                               : "—")</span>
                                    </td>
                                    <td class="text-muted small fw-normal d-none d-md-table-cell">
                                        <span>@(match.Player1IsAttacker == true  ? match.Player1?.Name ?? "P1"
                                               : match.Player1IsAttacker == false ? match.Player2?.Name ?? "P2"
                                               : "—")</span>
                                    </td>
                                    <td class="fw-normal">
                                        @if (match.Player2Id is null)
                                        {
                                            <span class="text-muted">bye</span>
                                        }
                                        else if (match.IsScored)
                                        {
                                            <span>@match.Player1Score — @match.Player2Score</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">pending</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    @* ── Check-in ──────────────────────────────────────────────────────────────── *@
    @if (_tournament.CheckInEnabled && _myPlayerId.HasValue &&
         (_tournament.Status == TournamentStatus.Upcoming || _tournament.Status == TournamentStatus.InProgress))
    {
        var myPlayer = _players.FirstOrDefault(p => p.Id == _myPlayerId);
        @if (myPlayer is not null)
        {
            <div class="mb-4">
                @if (myPlayer.IsCheckedIn)
                {
                    <span class="badge text-bg-success fs-6">✓ Checked in</span>
                }
                else
                {
                    <button class="btn btn-success" @onclick="CheckIn" disabled="@_checkInBusy">
                        @(_checkInBusy ? "Checking in…" : "Check in to this tournament")
                    </button>
                }
            </div>
        }
    }

    @* ── Sportsmanship ratings ──────────────────────────────────────────────────── *@
    @if (_myPlayerId.HasValue && _ratedMatches.Any(x => !RatingGiven(x.match)))
    {
        <div class="card mb-4" style="max-width:500px">
            <div class="card-body">
                <h2 class="h6 card-title mb-3">Rate your opponents</h2>
                @foreach (var (rn, match) in _ratedMatches.Where(x => !RatingGiven(x.match)))
                {
                    var opp = match.Player1Id == _myPlayerId ? match.Player2 : match.Player1;
                    <div class="mb-3">
                        <div class="small text-muted mb-1">R@(rn) — vs @(opp?.Name ?? "opponent")</div>
                        <div class="d-flex gap-1">
                            @for (var star = 1; star <= 5; star++)
                            {
                                var s = star;
                                <button class="btn btn-sm btn-outline-warning px-2"
                                        @onclick="() => SubmitSportsRating(match.Id, s)"
                                        disabled="@_sportsRatingBusy">
                                    @(s <= (_pendingSportsRating.GetValueOrDefault(match.Id)) ? "★" : "☆")
                                </button>
                            }
                            @if (_pendingSportsRating.ContainsKey(match.Id))
                            {
                                <button class="btn btn-sm btn-primary ms-2"
                                        @onclick="() => SaveSportsRating(match.Id)"
                                        disabled="@_sportsRatingBusy">Save</button>
                                <button class="btn btn-sm btn-link text-muted"
                                        @onclick="() => _pendingSportsRating.Remove(match.Id)">Clear</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── Standings ─────────────────────────────────────────────────────────────── *@
    @if (_standings.Any())
    {
        var orderedRounds = _allRounds.OrderBy(r => r.Round.RoundNumber).ToList();
        <h2 class="h5 mt-4">Standings</h2>
        <div class="table-responsive mb-4">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th class="d-none d-sm-table-cell">Faction</th>
                        @foreach (var (r, _) in orderedRounds)
                        {
                            <th class="text-center small standings-round-col">R@(r.RoundNumber)</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{var pos = 1;}
                    @foreach (var standing in _standings)
                    {
                        var player = _players.FirstOrDefault(p => p.Id == standing.PlayerId);
                        <tr>
                            <td>@pos</td>
                            <td>@PlayerNameCell(player)</td>
                            <td class="d-none d-sm-table-cell">@(player?.ArmyFaction ?? "—")</td>
                            @foreach (var (_, matches) in orderedRounds)
                            {
                                var m = matches.FirstOrDefault(x =>
                                    x.Player1Id == standing.PlayerId || x.Player2Id == standing.PlayerId);
                                @if (m is null || !m.IsScored)
                                {
                                    <td class="text-center text-muted small standings-round-col">—</td>
                                }
                                else
                                {
                                    var (ds, dc) = RoundScore(m, standing.PlayerId);
                                    <td class="text-center small fw-semibold standings-round-col @dc">@ds</td>
                                }
                            }
                        </tr>
                        pos++;
                    }
                </tbody>
            </table>
        </div>
    }

    @* ── Players ───────────────────────────────────────────────────────────────── *@
    <h2 class="h5 mt-4">Players (@_players.Count(p => !p.IsDropped))</h2>
    @if (!_players.Any())
    {
        <p class="text-muted">No players registered yet.</p>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-sm">
                <thead>
                    <tr><th>Name</th><th class="d-none d-sm-table-cell">Faction</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var player in _players.OrderBy(p => p.Name))
                    {
                        <tr>
                            <td>@PlayerNameCell(player)</td>
                            <td class="d-none d-sm-table-cell">@(player.ArmyFaction ?? "—")</td>
                            <td>@(player.IsDropped ? "Dropped" : "Active")</td>
                            <td>
                                @if (_myPlayerId.HasValue && player.Id != _myPlayerId)
                                {
                                    <button class="btn btn-sm btn-link text-danger p-0"
                                            title="Report player"
                                            @onclick="() => StartReport(player.Id)">🚩</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @* Report inline form *@
        @if (_reportingPlayerId.HasValue)
        {
            var rp = _players.FirstOrDefault(p => p.Id == _reportingPlayerId);
            <div class="card mt-3 border-danger" style="max-width:480px">
                <div class="card-body">
                    <h6 class="card-title text-danger">Report @(rp?.Name ?? "player")</h6>
                    @if (_reportSuccess)
                    {
                        <div class="alert alert-success py-2 small">Report submitted. The organizer has been notified.</div>
                    }
                    else
                    {
                        <textarea class="form-control mb-2" rows="3" maxlength="500"
                                  @bind="_reportReason"
                                  placeholder="Describe the issue (max 500 chars)" />
                        <button class="btn btn-sm btn-danger me-2"
                                @onclick="SubmitReport"
                                disabled="@(string.IsNullOrWhiteSpace(_reportReason) || _reportSubmitting)">
                            Submit report
                        </button>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => _reportingPlayerId = null">Cancel</button>
                    }
                </div>
            </div>
        }
    }
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Parameter] public string Slug { get; set; } = string.Empty;

    private Tournament? _tournament;
    private List<Player> _players = [];
    private List<PlayerStanding> _standings = [];
    /// <summary>All rounds newest-first, each paired with its match list.</summary>
    // _allRounds kept for the standings per-round grid; not rendered directly
    private List<(Round Round, List<Match> Matches)> _allRounds = [];
    // Only one round shown on the page: the latest incomplete, or last complete if all done
    private Round? _currentRound;
    private List<Match> _currentMatches = [];
    private Dictionary<string, PlayerRating> _playerRatings = [];
    private List<Organization> _userOrgs = [];
    private Guid? _selectedOrgId;
    private bool _loading = true;
    // Team state
    private List<Team> _teams = [];
    private Team? _myTeam;
    private bool _isCaptain;
    private string _newTeamName = string.Empty;
    private string _joinCode = string.Empty;
    private string? _addName;
    private string? _addEmail;
    private bool _teamBusy;
    private string? _teamError;
    private string? _teamSuccess;
    private Guid? _confirmRemovePlayer;
    private Guid? _editingMember;
    private string? _editMemberFaction;
    private string? _editMemberArmyList;
    private bool _inviteCopied;
    private bool _checkInBusy;
    private bool _sportsRatingBusy;
    private Dictionary<Guid, int> _pendingSportsRating = [];
    // (roundNumber, match) for scored matches the current player participated in
    private List<(int rn, Match match)> _ratedMatches = [];
    private string? _sessionEmail;
    private Guid? _myPlayerId;
    private Match? _myCurrentMatch;   // unscored match in the latest incomplete round
    private bool _alreadyRegistered;

    // Registration form
    private readonly RegModel _regModel = new();
    private string? _regError;
    private bool _regSubmitting;
    private bool _registrationSuccess;
    private bool _myRegistrationSuccess;

    // Match result submission
    private int? _submitMyScore;
    private int? _submitOpponentScore;
    private bool? _submitIWentFirst;
    private bool? _submitIWasAttacker;
    private bool _submitBusy;
    private string? _submitError;
    private bool _submitSuccess;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        _sessionEmail = authState.User.FindFirst(ClaimTypes.Email)?.Value;

        _tournament = await TournamentService.GetBySlugAsync(Slug);
        if (_tournament is not null)
        {
            _players = [.. await PlayerService.ListByTournamentAsync(_tournament.Id)];
            _standings = [.. await StandingsService.ComputeAsync(_tournament.Id, _tournament.ScoringSystem, _tournament.Tiebreakers)];

            if (_sessionEmail is not null)
            {
                var myPlayer = _players.FirstOrDefault(p =>
                    !p.IsDropped &&
                    string.Equals(p.Email, _sessionEmail, StringComparison.OrdinalIgnoreCase));
                _myPlayerId = myPlayer?.Id;
                _alreadyRegistered = myPlayer is not null;
            }

            var rounds = await RoundService.ListByTournamentAsync(_tournament.Id);
            // Build all-rounds list (ascending order) for the standings grid
            _allRounds = [];
            foreach (var r in rounds.OrderBy(r => r.RoundNumber))
            {
                var matches = new List<Match>(await RoundService.GetMatchesAsync(r.Id));
                _allRounds.Add((r, matches));
            }
            // Current round = latest incomplete, or last complete if all done
            var currentEntry = _allRounds.LastOrDefault(x => !x.Round.IsComplete);
            if (currentEntry == default) currentEntry = _allRounds.LastOrDefault();
            if (currentEntry != default)
            {
                _currentRound   = currentEntry.Round;
                _currentMatches = currentEntry.Matches;
            }
            // Track the logged-in player's unscored match in the current round
            if (_myPlayerId.HasValue && _currentMatches.Any())
            {
                _myCurrentMatch = _currentMatches.FirstOrDefault(m =>
                    (m.Player1Id == _myPlayerId || m.Player2Id == _myPlayerId)
                    && !m.IsScored && m.Player2Id is not null);
            }
        }
        // Build rated-matches list for sportsmanship UI
        if (_myPlayerId.HasValue)
        {
            _ratedMatches = _allRounds
                .OrderBy(x => x.Round.RoundNumber)
                .SelectMany(x => x.Matches
                    .Where(m => m.IsScored && m.Player2Id is not null &&
                                (m.Player1Id == _myPlayerId || m.Player2Id == _myPlayerId))
                    .Select(m => (x.Round.RoundNumber, m)))
                .ToList();
        }

        // Load teams for team events
        if (_tournament.IsTeamEvent)
        {
            _teams = [.. await TeamService.ListByTournamentAsync(_tournament.Id)];
            if (_myPlayerId.HasValue)
            {
                _myTeam = _teams.FirstOrDefault(t => t.Players.Any(p => p.Id == _myPlayerId));
                _isCaptain = _myTeam?.CaptainPlayerId == _myPlayerId;
            }
        }

        var ratingList = await EloService.GetLeaderboardAsync();
        _playerRatings = ratingList.ToDictionary(r => r.Email, StringComparer.OrdinalIgnoreCase);

        // Load user's organisations for the registration org-picker
        if (_sessionEmail is not null)
        {
            var user = await AuthService.GetByEmailAsync(_sessionEmail);
            if (user is not null)
            {
                _userOrgs = [.. await OrgService.ListByUserAsync(user.Id)];
                // Pre-select if only one org
                if (_userOrgs.Count == 1) _selectedOrgId = _userOrgs[0].Id;
            }
        }

        _loading = false;
    }

    /// Returns (displayScore, cssClass) for a player's match in the standings grid.
    private async Task RefreshRoundsAsync()
    {
        if (_tournament is null) return;
        var rounds = await RoundService.ListByTournamentAsync(_tournament.Id);
        _allRounds = [];
        foreach (var r in rounds.OrderBy(r => r.RoundNumber))
            _allRounds.Add((r, new List<Match>(await RoundService.GetMatchesAsync(r.Id))));

        var currentEntry = _allRounds.LastOrDefault(x => !x.Round.IsComplete);
        if (currentEntry == default) currentEntry = _allRounds.LastOrDefault();
        if (currentEntry != default)
        {
            _currentRound   = currentEntry.Round;
            _currentMatches = currentEntry.Matches;
        }
        if (_myPlayerId.HasValue)
            _myCurrentMatch = _currentMatches.FirstOrDefault(m =>
                (m.Player1Id == _myPlayerId || m.Player2Id == _myPlayerId)
                && !m.IsScored && m.Player2Id is not null);
    }

    private (int score, string css) RoundScore(Match m, Guid playerId)
    {
        var isP1 = m.Player1Id == playerId;
        var raw  = isP1 ? (m.Player1Score ?? 0) : (m.Player2Score ?? 0);
        var oRaw = isP1 ? (m.Player2Score ?? 0) : (m.Player1Score ?? 0);

        if (_tournament?.ScoringSystem == ScoringSystem.Wtc)
        {
            var (g1, g2) = WtcScoring.ConvertToGamePoints(m.Player1Score ?? 0, m.Player2Score ?? 0);
            var gp = isP1 ? g1 : g2;
            var css = gp > 10 ? "text-success" : gp < 10 ? "text-danger" : "text-info";
            return (gp, css);
        }
        else
        {
            var css = raw > oRaw ? "text-success" : raw < oRaw ? "text-danger" : "text-info";
            return (raw, css);
        }
    }

    // ── Check-in ──────────────────────────────────────────────────────────────
    // ── Team handlers ─────────────────────────────────────────────────────────

    private async Task RefreshTeams()
    {
        if (_tournament is null) return;
        _teams = [.. await TeamService.ListByTournamentAsync(_tournament.Id)];
        if (_myPlayerId.HasValue)
        {
            _myTeam = _teams.FirstOrDefault(t => t.Players.Any(p => p.Id == _myPlayerId));
            _isCaptain = _myTeam?.CaptainPlayerId == _myPlayerId;
        }
    }

    private async Task CreateTeam()
    {
        if (_tournament is null || _sessionEmail is null || string.IsNullOrWhiteSpace(_newTeamName)) return;
        _teamBusy = true; _teamError = null;
        try
        {
            // Register player first if not already
            var myPlayer = _players.FirstOrDefault(p =>
                string.Equals(p.Email, _sessionEmail, StringComparison.OrdinalIgnoreCase));
            if (myPlayer is null)
            {
                myPlayer = await PlayerService.RegisterAsync(new Services.Players.RegisterPlayerRequest(
                    TournamentId: _tournament.Id, Name: _sessionEmail.Split('@')[0],
                    Email: _sessionEmail, ArmyFaction: null, ArmyList: null));
                _players = [.. await PlayerService.ListByTournamentAsync(_tournament.Id)];
                _myPlayerId = myPlayer.Id;
                _alreadyRegistered = true;
            }
            await TeamService.CreateTeamAsync(_tournament.Id, _newTeamName, myPlayer.Id);
            _newTeamName = string.Empty;
            await RefreshTeams();
            _teamSuccess = "Team created! Share the invite link with your teammates.";
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    private async Task JoinWithCode()
    {
        if (_tournament is null || _sessionEmail is null || string.IsNullOrWhiteSpace(_joinCode)) return;
        _teamBusy = true; _teamError = null;
        try
        {
            var team = await TeamService.GetByInviteTokenAsync(_joinCode.Trim());
            if (team is null || team.TournamentId != _tournament.Id)
                throw new InvalidOperationException("Invalid invite code.");

            var myPlayer = _players.FirstOrDefault(p =>
                string.Equals(p.Email, _sessionEmail, StringComparison.OrdinalIgnoreCase));
            if (myPlayer is null)
            {
                myPlayer = await PlayerService.RegisterAsync(new Services.Players.RegisterPlayerRequest(
                    TournamentId: _tournament.Id, Name: _sessionEmail.Split('@')[0],
                    Email: _sessionEmail, ArmyFaction: null, ArmyList: null));
                _players = [.. await PlayerService.ListByTournamentAsync(_tournament.Id)];
                _myPlayerId = myPlayer.Id;
            }
            await TeamService.JoinTeamAsync(team.Id, myPlayer.Id);
            _joinCode = string.Empty;
            await RefreshTeams();
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    private async Task AddPlayerManually()
    {
        if (_myTeam is null || string.IsNullOrWhiteSpace(_addName)) return;
        _teamBusy = true; _teamError = null;
        try
        {
            await TeamService.AddPlayerManuallyAsync(_myTeam.Id, _addName!, _addEmail);
            _addName = _addEmail = null;
            _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
            await RefreshTeams();
            _teamSuccess = "Player added.";
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    private async Task RemoveTeamPlayer(Guid playerId)
    {
        _confirmRemovePlayer = null; _teamBusy = true; _teamError = null;
        try
        {
            await TeamService.RemoveFromTeamAsync(playerId);
            _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
            await RefreshTeams();
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    private async Task TransferCaptain(Guid newCaptainId)
    {
        if (_myTeam is null) return;
        _teamBusy = true; _teamError = null;
        try
        {
            await TeamService.TransferCaptainAsync(_myTeam.Id, newCaptainId);
            await RefreshTeams();
            _isCaptain = _myTeam?.CaptainPlayerId == _myPlayerId;
            _teamSuccess = "Captain transferred.";
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    private async Task SaveMemberEdit(Guid playerId)
    {
        _teamBusy = true; _teamError = null;
        try
        {
            await TeamService.UpdateTeamMemberAsync(playerId, _editMemberFaction, _editMemberArmyList);
            _editingMember = null;
            _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
            await RefreshTeams();
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    private async Task CopyInviteLink()
    {
        if (_myTeam is null) return;
        var url = $"{Nav.BaseUri.TrimEnd('/')}/t/{Slug}/join-team?code={_myTeam.InviteToken}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
        _inviteCopied = true;
        StateHasChanged();
    }

    private async Task InviteOrgMember(string? email)
    {
        if (_myTeam is null || string.IsNullOrWhiteSpace(email)) return;
        _teamBusy = true; _teamError = null;
        try
        {
            var displayName = _playerRatings.TryGetValue(email, out var r) ? r.DisplayName : email.Split('@')[0];
            await TeamService.AddPlayerManuallyAsync(_myTeam.Id, displayName, email);
            _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
            await RefreshTeams();
            _teamSuccess = $"{displayName} added to the team.";
        }
        catch (Exception ex) { _teamError = ex.Message; }
        finally { _teamBusy = false; }
    }

    // Org members not already on this team or in this tournament
    private List<PlayerRating> OrgMembersNotOnTeam(Organization org)
    {
        var registeredEmails = _players.Select(p => p.Email?.ToLowerInvariant()).ToHashSet();
        return org.Members
            .Where(m => !string.Equals(m.User.Email, _sessionEmail, StringComparison.OrdinalIgnoreCase))
            .Select(m => _playerRatings.TryGetValue(m.User.Email, out var r) ? r : new PlayerRating { Email = m.User.Email, DisplayName = m.User.Email })
            .Where(r => !registeredEmails.Contains(r.Email.ToLowerInvariant()))
            .ToList();
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task CheckIn()
    {
        if (_myPlayerId is null) return;
        _checkInBusy = true;
        await PlayerService.SetCheckInAsync(_myPlayerId.Value, true);
        _players = [.. await PlayerService.ListByTournamentAsync(_tournament!.Id)];
        _checkInBusy = false;
    }

    // ── Sportsmanship ─────────────────────────────────────────────────────────
    private bool RatingGiven(Match m) =>
        _myPlayerId.HasValue &&
        (m.Player1Id == _myPlayerId ? m.Player1SportsRating.HasValue : m.Player2SportsRating.HasValue);

    private void SubmitSportsRating(Guid matchId, int stars) =>
        _pendingSportsRating[matchId] = stars;

    private async Task SaveSportsRating(Guid matchId)
    {
        if (!_pendingSportsRating.TryGetValue(matchId, out var rating) || _myPlayerId is null) return;
        _sportsRatingBusy = true;
        try
        {
            await RoundService.SetSportsRatingAsync(matchId, _myPlayerId.Value, rating);
            _pendingSportsRating.Remove(matchId);
            await RefreshRoundsAsync();
            // Rebuild rated matches
            _ratedMatches = _allRounds
                .OrderBy(x => x.Round.RoundNumber)
                .SelectMany(x => x.Matches
                    .Where(m => m.IsScored && m.Player2Id is not null &&
                                (m.Player1Id == _myPlayerId || m.Player2Id == _myPlayerId))
                    .Select(m => (x.Round.RoundNumber, m)))
                .ToList();
        }
        finally { _sportsRatingBusy = false; }
    }

    // ── Report player ─────────────────────────────────────────────────────────
    private Guid? _reportingPlayerId;
    private string _reportReason = string.Empty;
    private bool _reportSubmitting;
    private bool _reportSuccess;

    private void StartReport(Guid playerId)
    {
        _reportingPlayerId = playerId;
        _reportReason = string.Empty;
        _reportSuccess = false;
    }

    private async Task SubmitReport()
    {
        if (_reportingPlayerId is null || string.IsNullOrWhiteSpace(_reportReason)) return;
        _reportSubmitting = true;
        try
        {
            await PlayerReportService.FileReportAsync(
                _tournament!.Id, _myPlayerId, _reportingPlayerId.Value, _reportReason);
            _reportSuccess = true;
            _reportingPlayerId = null;
        }
        finally { _reportSubmitting = false; }
    }

    private RenderFragment PlayerNameCell(Player? player) => __builder =>
    {
        if (player is null) { __builder.AddContent(0, "—"); return; }
        // Always link to the tournament-scoped player profile; from there they can reach global ELO.
        __builder.OpenElement(0, "a");
        __builder.AddAttribute(1, "href", $"/t/{Slug}/player/{player.Id}");
        __builder.AddContent(2, player.Name);
        __builder.CloseElement();
    };

    private async Task SubmitMatchResult()
    {
        if (_myCurrentMatch is null || _myPlayerId is null) return;
        if (_submitMyScore is null || _submitOpponentScore is null
            || _submitIWentFirst is null || _submitIWasAttacker is null) return;

        _submitBusy = true;
        _submitError = null;
        _submitSuccess = false;
        try
        {
            await RoundService.SubmitMatchResultAsync(
                _myCurrentMatch.Id,
                _myPlayerId.Value,
                _submitMyScore.Value,
                _submitOpponentScore.Value,
                _submitIWentFirst.Value,
                _submitIWasAttacker.Value);

            await RefreshRoundsAsync();
            _standings = [.. await StandingsService.ComputeAsync(_tournament!.Id, _tournament.ScoringSystem, _tournament.Tiebreakers)];
            _submitSuccess = true;
        }
        catch (Exception ex)
        {
            _submitError = ex.Message;
        }
        finally
        {
            _submitBusy = false;
        }
    }

    private async Task HandleRegister()
    {
        if (_tournament is null || _sessionEmail is null) return;
        _regSubmitting = true;
        _regError = null;
        try
        {
            await PlayerService.RegisterAsync(new Services.Players.RegisterPlayerRequest(
                TournamentId: _tournament.Id,
                Name: _regModel.Name,
                Email: _sessionEmail,
                ArmyFaction: _regModel.ArmyFaction,
                ArmyList: _regModel.ArmyList,
                OrganizationId: _selectedOrgId
            ));
            _players = [.. await PlayerService.ListByTournamentAsync(_tournament.Id)];
            _standings = [.. await StandingsService.ComputeAsync(_tournament.Id, _tournament.ScoringSystem, _tournament.Tiebreakers)];
            await RefreshRoundsAsync();
            _registrationSuccess = true;
            _myRegistrationSuccess = true;
        }
        catch
        {
            _regError = "Registration failed. Please try again.";
        }
        finally
        {
            _regSubmitting = false;
        }
    }

    private sealed class RegModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Name is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? ArmyFaction { get; set; }

        public string? ArmyList { get; set; }
    }
}
