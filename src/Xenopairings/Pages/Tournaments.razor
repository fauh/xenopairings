@page "/tournaments"
@using Xenopairings.Models
@using Xenopairings.Services.Tournaments
@using Xenopairings.Services.Players
@inject ITournamentService TournamentService
@inject IPlayerService PlayerService

<PageTitle>Tournaments — Xenopairings</PageTitle>

<h1>Tournaments</h1>

@if (_loading)
{
    <LoadingSpinner />
}
else if (!_upcoming.Any() && !_past.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon" aria-hidden="true">🎲</div>
        <h3>No tournaments yet</h3>
        <p>Be the first to create one.</p>
        <a href="/new" class="btn btn-primary mt-2">Create a tournament</a>
    </div>
}
else
{
    @if (_upcoming.Any())
    {
        <div class="table-responsive mb-4">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Tournament</th>
                        <th>Date</th>
                        <th>Rounds</th>
                        <th>Players</th>
                        <th>Registration</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _upcoming)
                    {
                        <tr>
                            <td><a href="/t/@row.Tournament.Slug">@row.Tournament.Title</a></td>
                            <td class="text-nowrap">@row.Tournament.StartsAt.ToLocalTime().ToString("d MMM yyyy")</td>
                            <td>@row.Tournament.NumberOfRounds</td>
                            <td>@row.PlayerCount / @row.Tournament.MaxPlayers</td>
                            <td>
                                @if (row.Tournament.IsClosed)
                                {
                                    <span class="badge text-bg-secondary">Closed</span>
                                }
                                else if (row.Tournament.RegistrationOpen)
                                {
                                    <span class="badge text-bg-success">Open</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-warning">Closed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_past.Any())
    {
        <details>
            <summary class="text-muted mb-2" style="cursor:pointer">Past tournaments (@_past.Count)</summary>
            <div class="table-responsive mt-2">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Tournament</th>
                            <th>Date</th>
                            <th>Rounds</th>
                            <th>Players</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _past)
                        {
                            <tr>
                                <td><a href="/t/@row.Tournament.Slug">@row.Tournament.Title</a></td>
                                <td class="text-nowrap">@row.Tournament.StartsAt.ToLocalTime().ToString("d MMM yyyy")</td>
                                <td>@row.Tournament.NumberOfRounds</td>
                                <td>@row.PlayerCount / @row.Tournament.MaxPlayers</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </details>
    }

    <a href="/new" class="btn btn-primary btn-sm mt-3">Create a tournament</a>
}

@code {
    private record TournamentRow(Tournament Tournament, int PlayerCount);

    private List<TournamentRow> _upcoming = [];
    private List<TournamentRow> _past = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var tournaments = await TournamentService.ListPublicAsync();
        var now = DateTimeOffset.UtcNow;

        var rows = new List<TournamentRow>();
        foreach (var t in tournaments)
        {
            var players = await PlayerService.ListByTournamentAsync(t.Id);
            rows.Add(new TournamentRow(t, players.Count(p => !p.IsDropped)));
        }

        _upcoming = [.. rows.Where(r => r.Tournament.StartsAt >= now)
                             .OrderBy(r => r.Tournament.StartsAt)];
        _past     = [.. rows.Where(r => r.Tournament.StartsAt < now)
                             .OrderByDescending(r => r.Tournament.StartsAt)];
        _loading = false;
    }
}
