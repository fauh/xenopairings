@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

<nav class="app-topnav" aria-label="Main navigation">
    <a class="navbar-brand" href="/">Xenopairings</a>

    <div class="nav-actions">
        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Home</NavLink>
        <NavLink class="nav-link" href="/tournaments">Browse</NavLink>
        <NavLink class="nav-link" href="/leaderboard">Leaderboard</NavLink>
        <NavLink class="nav-link" href="/new">New tournament</NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="nav-link" href="/dashboard">Dashboard</NavLink>
                <NavLink class="nav-link" href="/organizations">Organizations</NavLink>
                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <Authorized>
                        <NavLink class="nav-link" href="/admin">Admin</NavLink>
                    </Authorized>
                </AuthorizeView>
                <form method="post" action="/logout" style="display:inline">
                    <AntiforgeryToken />
                    <button type="submit" class="nav-link btn btn-link p-0">Sign out</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a class="nav-link" href="/login">Sign in</a>
                <a class="nav-link" href="/register">Register</a>
            </NotAuthorized>
        </AuthorizeView>

        <button class="btn-theme-toggle" @onclick="ToggleTheme"
                aria-label="@(_isDark ? "Switch to light mode" : "Switch to dark mode")"
                aria-pressed="@_isDark"
                title="@(_isDark ? "Switch to light mode" : "Switch to dark mode")">
            <span aria-hidden="true">@(_isDark ? "☀️" : "🌙")</span>
        </button>
    </div>
</nav>

@* Email verification banner — shown when logged in but not yet verified *@
@if (_showVerifyBanner)
{
    <div class="alert alert-warning mb-0 rounded-0 py-2 small text-center">
        📧 Please verify your email address.
        <button class="btn btn-link btn-sm py-0 alert-link" @onclick="ResendVerification" disabled="@_resendBusy">
            @(_resendSent ? "Sent!" : "Resend verification email")
        </button>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private Xenopairings.Services.Auth.IAuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _isDark;
    private bool _showVerifyBanner;
    private bool _resendBusy;
    private bool _resendSent;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var verified = user.FindFirst("email_verified")?.Value;
            _showVerifyBanner = verified != "true";
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", _isDark ? "dark" : "light");
    }

    private async Task ResendVerification()
    {
        var authState = await AuthStateTask;
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId is null || !Guid.TryParse(userId, out var uid)) return;

        _resendBusy = true;
        var baseUrl = Nav.BaseUri.TrimEnd('/');
        await AuthService.SendVerificationEmailAsync(uid, baseUrl);
        _resendSent = true;
        _resendBusy = false;
    }
}
