@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

<nav class="app-topnav @(_navOpen ? "nav-open" : "")" aria-label="Main navigation">
    <a class="navbar-brand" href="/" @onclick="CloseNav">Xenopairings</a>

    @* Hamburger — only visible on mobile via CSS *@
    <button class="nav-toggle" @onclick="ToggleNav"
            aria-label="@(_navOpen ? "Close menu" : "Open menu")"
            aria-expanded="@_navOpen">
        @(_navOpen ? "✕" : "☰")
    </button>

    <div class="nav-actions">
        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All" @onclick="CloseNav">Home</NavLink>
        <NavLink class="nav-link" href="/tournaments" @onclick="CloseNav">Browse</NavLink>
        <NavLink class="nav-link" href="/leaderboard" @onclick="CloseNav">Leaderboard</NavLink>
        <NavLink class="nav-link" href="/new" @onclick="CloseNav">New tournament</NavLink>

        <AuthorizeView>
            <Authorized>
                <NavLink class="nav-link" href="/dashboard" @onclick="CloseNav">Dashboard</NavLink>
                <NavLink class="nav-link" href="/account" @onclick="CloseNav">Account</NavLink>
                <NavLink class="nav-link" href="/organizations" @onclick="CloseNav">Organizations</NavLink>
                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <Authorized>
                        <NavLink class="nav-link" href="/admin" @onclick="CloseNav">Admin</NavLink>
                    </Authorized>
                </AuthorizeView>
                <form method="post" action="/logout" style="display:inline">
                    <AntiforgeryToken />
                    <button type="submit" class="nav-link btn btn-link p-0">Sign out</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a class="nav-link" href="/login" @onclick="CloseNav">Sign in</a>
                <a class="nav-link" href="/register" @onclick="CloseNav">Register</a>
            </NotAuthorized>
        </AuthorizeView>

        <button class="btn-theme-toggle" @onclick="ToggleTheme"
                aria-label="@(_isDark ? "Switch to light mode" : "Switch to dark mode")"
                aria-pressed="@_isDark"
                title="@(_isDark ? "Switch to light mode" : "Switch to dark mode")">
            <span aria-hidden="true">@(_isDark ? "☀️" : "🌙")</span>
        </button>
    </div>
</nav>

@* Email verification banner *@
@if (_showVerifyBanner)
{
    <div class="alert alert-warning mb-0 rounded-0 py-2 small text-center">
        📧 Please verify your email address.
        <button class="btn btn-link btn-sm py-0 alert-link" @onclick="ResendVerification" disabled="@_resendBusy">
            @(_resendSent ? "Sent!" : "Resend verification email")
        </button>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private Xenopairings.Services.Auth.IAuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _isDark = true;  // default: dark
    private bool _navOpen;
    private bool _showVerifyBanner;
    private bool _resendBusy;
    private bool _resendSent;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        if (user.Identity?.IsAuthenticated != true) return;

        var claimVerified = user.FindFirst("email_verified")?.Value == "true";
        if (claimVerified)
        {
            // Cookie is up to date — no banner needed, no DB round-trip.
            _showVerifyBanner = false;
            return;
        }

        // Claim says unverified — but the cookie may be stale (user verified
        // their email before the cookie-refresh fix was deployed, or a long-lived
        // session is still active). Check the database for ground truth.
        var email = user.FindFirst(ClaimTypes.Email)?.Value;
        if (email is not null)
        {
            var dbUser = await AuthService.GetByEmailAsync(email);
            _showVerifyBanner = !(dbUser?.EmailVerified ?? false);
        }
        else
        {
            _showVerifyBanner = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // Read saved preference — default to dark if nothing stored
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "xp-theme");
            _isDark = saved is null ? true : saved == "dark";
            // Ensure the DOM attribute matches (in case SSR set the wrong default)
            await JS.InvokeVoidAsync(
                "document.documentElement.setAttribute",
                "data-theme", _isDark ? "dark" : "light");
            StateHasChanged();
        }
        catch { /* localStorage unavailable (SSR pass) */ }
    }

    private void ToggleNav() => _navOpen = !_navOpen;
    private void CloseNav()  => _navOpen = false;

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        var theme = _isDark ? "dark" : "light";
        await JS.InvokeVoidAsync("document.documentElement.setAttribute", "data-theme", theme);
        try { await JS.InvokeVoidAsync("localStorage.setItem", "xp-theme", theme); }
        catch { }
    }

    private async Task ResendVerification()
    {
        var authState = await AuthStateTask;
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId is null || !Guid.TryParse(userId, out var uid)) return;

        _resendBusy = true;
        var baseUrl = Nav.BaseUri.TrimEnd('/');
        await AuthService.SendVerificationEmailAsync(uid, baseUrl);
        _resendSent = true;
        _resendBusy = false;
    }
}
