@* Reusable score-entry form: Primary + Secondary + Battle Ready for each player.
   Shows WTC GP conversion when ScoringSystem == Wtc. *@
@using Xenopairings.Models
@using Xenopairings.Services.Pairings
@using Xenopairings.Services.Rounds

<div class="score-entry-form">

    @* ── Score rows ── *@
    <div class="row g-2 mb-2">
        <div class="col">
            <div class="score-entry-header small fw-semibold text-muted mb-1">@Player1Label</div>
            <div class="mb-1">
                <label class="form-label small mb-0">Primary <span class="text-muted">(0–45)</span></label>
                <input type="number" class="form-control form-control-sm"
                       min="0" max="45" placeholder="0"
                       value="@P1Primary"
                       @oninput="e => P1PrimaryChanged.InvokeAsync(ParseClamped(e.Value?.ToString(), 0, 45))"
                       disabled="@Disabled" />
            </div>
            <div class="mb-1">
                <label class="form-label small mb-0">Secondary <span class="text-muted">(0–45)</span></label>
                <input type="number" class="form-control form-control-sm"
                       min="0" max="45" placeholder="0"
                       value="@P1Secondary"
                       @oninput="e => P1SecondaryChanged.InvokeAsync(ParseClamped(e.Value?.ToString(), 0, 45))"
                       disabled="@Disabled" />
            </div>
            <div class="form-check mt-1">
                <input class="form-check-input" type="checkbox" id="p1br-@_id"
                       checked="@P1BattleReady"
                       @onchange="e => P1BattleReadyChanged.InvokeAsync((bool)(e.Value ?? true))"
                       disabled="@Disabled" />
                <label class="form-check-label small" for="p1br-@_id">
                    Battle Ready <span class="text-muted">(+10)</span>
                </label>
            </div>
            @if (P1Primary.HasValue && P1Secondary.HasValue)
            {
                var total = ScoreCalculator.ComputeTotal(P1Primary.Value, P1Secondary.Value, P1BattleReady);
                <div class="mt-1 small fw-semibold">Total: @total</div>
            }
        </div>

        <div class="col-auto d-flex align-items-center">
            <span class="text-muted fw-bold">—</span>
        </div>

        <div class="col">
            <div class="score-entry-header small fw-semibold text-muted mb-1">@Player2Label</div>
            <div class="mb-1">
                <label class="form-label small mb-0">Primary <span class="text-muted">(0–45)</span></label>
                <input type="number" class="form-control form-control-sm"
                       min="0" max="45" placeholder="0"
                       value="@P2Primary"
                       @oninput="e => P2PrimaryChanged.InvokeAsync(ParseClamped(e.Value?.ToString(), 0, 45))"
                       disabled="@Disabled" />
            </div>
            <div class="mb-1">
                <label class="form-label small mb-0">Secondary <span class="text-muted">(0–45)</span></label>
                <input type="number" class="form-control form-control-sm"
                       min="0" max="45" placeholder="0"
                       value="@P2Secondary"
                       @oninput="e => P2SecondaryChanged.InvokeAsync(ParseClamped(e.Value?.ToString(), 0, 45))"
                       disabled="@Disabled" />
            </div>
            <div class="form-check mt-1">
                <input class="form-check-input" type="checkbox" id="p2br-@_id"
                       checked="@P2BattleReady"
                       @onchange="e => P2BattleReadyChanged.InvokeAsync((bool)(e.Value ?? true))"
                       disabled="@Disabled" />
                <label class="form-check-label small" for="p2br-@_id">
                    Battle Ready <span class="text-muted">(+10)</span>
                </label>
            </div>
            @if (P2Primary.HasValue && P2Secondary.HasValue)
            {
                var total = ScoreCalculator.ComputeTotal(P2Primary.Value, P2Secondary.Value, P2BattleReady);
                <div class="mt-1 small fw-semibold">Total: @total</div>
            }
        </div>
    </div>

    @* ── Extended scoring — per-turn breakdown ── *@
    <details class="mt-3">
        <summary class="small text-muted" style="cursor:pointer">Extended scoring (per turn)</summary>
        <div class="mt-2">
            <div class="table-responsive">
                <table class="table table-sm table-borderless mb-0" style="max-width:420px">
                    <thead>
                        <tr>
                            <th class="text-muted small fw-normal" style="width:3rem">Turn</th>
                            <th class="small text-center" colspan="2">@Player1Label</th>
                            <th class="small text-center" colspan="2">@Player2Label</th>
                        </tr>
                        <tr>
                            <th></th>
                            <th class="small text-muted fw-normal text-center">Pri</th>
                            <th class="small text-muted fw-normal text-center">Sec</th>
                            <th class="small text-muted fw-normal text-center">Pri</th>
                            <th class="small text-muted fw-normal text-center">Sec</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var t = 0; t < _p1Turns.Count; t++)
                        {
                            var idx = t;
                            <tr>
                                <td class="text-muted small">T@(_p1Turns[idx].Turn)</td>
                                <td>
                                    <input type="number" class="form-control form-control-sm text-center" min="0" max="15"
                                           value="@_p1Turns[idx].Primary"
                                           @oninput="e => UpdateTurn(true, idx, true, e.Value?.ToString())"
                                           disabled="@Disabled" style="width:52px" />
                                </td>
                                <td>
                                    <input type="number" class="form-control form-control-sm text-center" min="0" max="15"
                                           value="@_p1Turns[idx].Secondary"
                                           @oninput="e => UpdateTurn(true, idx, false, e.Value?.ToString())"
                                           disabled="@Disabled" style="width:52px" />
                                </td>
                                <td>
                                    <input type="number" class="form-control form-control-sm text-center" min="0" max="15"
                                           value="@_p2Turns[idx].Primary"
                                           @oninput="e => UpdateTurn(false, idx, true, e.Value?.ToString())"
                                           disabled="@Disabled" style="width:52px" />
                                </td>
                                <td>
                                    <input type="number" class="form-control form-control-sm text-center" min="0" max="15"
                                           value="@_p2Turns[idx].Secondary"
                                           @oninput="e => UpdateTurn(false, idx, false, e.Value?.ToString())"
                                           disabled="@Disabled" style="width:52px" />
                                </td>
                            </tr>
                        }
                        @* Totals row *@
                        <tr class="fw-semibold">
                            <td class="text-muted small">Total</td>
                            <td class="text-center small">@TurnSum(_p1Turns, true)</td>
                            <td class="text-center small">@TurnSum(_p1Turns, false)</td>
                            <td class="text-center small">@TurnSum(_p2Turns, true)</td>
                            <td class="text-center small">@TurnSum(_p2Turns, false)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </details>

    @* ── WTC GP preview ── *@
    @if (ScoringSystem == ScoringSystem.Wtc && P1Primary.HasValue && P1Secondary.HasValue && P2Primary.HasValue && P2Secondary.HasValue)
    {
        var t1 = ScoreCalculator.ComputeTotal(P1Primary.Value, P1Secondary.Value, P1BattleReady);
        var t2 = ScoreCalculator.ComputeTotal(P2Primary.Value, P2Secondary.Value, P2BattleReady);
        var (gp1, gp2) = WtcScoring.ConvertToGamePoints(t1, t2);
        <div class="alert alert-secondary py-2 small mt-2">
            <strong>WTC game points:</strong>
            <span class="ms-2">@Player1Label <strong>@gp1</strong> — @Player2Label <strong>@gp2</strong></span>
            <span class="text-muted ms-2">(from totals @t1 — @t2)</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Player1Label { get; set; } = "Player 1";
    [Parameter] public string Player2Label { get; set; } = "Player 2";
    [Parameter] public ScoringSystem ScoringSystem { get; set; } = ScoringSystem.Gw;
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public int?  P1Primary        { get; set; }
    [Parameter] public int?  P1Secondary      { get; set; }
    [Parameter] public bool  P1BattleReady    { get; set; } = true;
    [Parameter] public int?  P2Primary        { get; set; }
    [Parameter] public int?  P2Secondary      { get; set; }
    [Parameter] public bool  P2BattleReady    { get; set; } = true;

    [Parameter] public EventCallback<int?>  P1PrimaryChanged     { get; set; }
    [Parameter] public EventCallback<int?>  P1SecondaryChanged   { get; set; }
    [Parameter] public EventCallback<bool>  P1BattleReadyChanged { get; set; }
    [Parameter] public EventCallback<int?>  P2PrimaryChanged     { get; set; }
    [Parameter] public EventCallback<int?>  P2SecondaryChanged   { get; set; }
    [Parameter] public EventCallback<bool>  P2BattleReadyChanged { get; set; }

    // Turn scores — passed back to parent so it can save them
    [Parameter] public IReadOnlyList<TurnScore>? P1TurnScores { get; set; }
    [Parameter] public IReadOnlyList<TurnScore>? P2TurnScores { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<TurnScore>> P1TurnScoresChanged { get; set; }
    [Parameter] public EventCallback<IReadOnlyList<TurnScore>> P2TurnScoresChanged { get; set; }

    // Unique id suffix so checkbox ids don't collide when multiple forms are on the same page
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];

    // Internal mutable lists — initialised from parameters
    private List<TurnScore> _p1Turns = ScoreCalculator.DefaultTurns();
    private List<TurnScore> _p2Turns = ScoreCalculator.DefaultTurns();

    protected override void OnParametersSet()
    {
        if (P1TurnScores is not null && P1TurnScores.Count > 0)
            _p1Turns = P1TurnScores.ToList();
        if (P2TurnScores is not null && P2TurnScores.Count > 0)
            _p2Turns = P2TurnScores.ToList();
    }

    private const int TurnPrimaryMax   = 15;
    private const int TurnSecondaryMax = 15;

    private void UpdateTurn(bool isP1, int idx, bool isPrimary, string? raw)
    {
        var list = isP1 ? _p1Turns : _p2Turns;
        if (idx < 0 || idx >= list.Count) return;
        int? val = null;
        if (int.TryParse(raw, out var n))
        {
            var max = isPrimary ? TurnPrimaryMax : TurnSecondaryMax;
            val = Math.Clamp(n, 0, max);
        }
        var old = list[idx];
        list[idx] = isPrimary
            ? new TurnScore(old.Turn, val, old.Secondary)
            : new TurnScore(old.Turn, old.Primary, val);

        var cb = isP1 ? P1TurnScoresChanged : P2TurnScoresChanged;
        _ = cb.InvokeAsync(list);
    }

    private static int? TurnSum(List<TurnScore> turns, bool isPrimary) =>
        turns.Any(t => isPrimary ? t.Primary.HasValue : t.Secondary.HasValue)
            ? turns.Sum(t => isPrimary ? (t.Primary ?? 0) : (t.Secondary ?? 0))
            : null;

    private static int? TryParseNullable(string? s) =>
        int.TryParse(s, out var n) ? n : null;

    /// <summary>
    /// Parse and hard-clamp to [min, max]. The HTML max attribute only
    /// blocks the spinner arrows — typed values bypass it entirely.
    /// </summary>
    private static int? ParseClamped(string? s, int min, int max) =>
        int.TryParse(s, out var n) ? Math.Clamp(n, min, max) : null;
}
